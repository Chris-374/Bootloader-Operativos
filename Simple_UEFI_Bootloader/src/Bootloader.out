   1:src/Bootloader.c **** //=================================================================================================
   2:src/Bootloader.c **** //  Simple UEFI Bootloader: Bootloader Entrypoint
   3:src/Bootloader.c **** //=================================================================================================
   4:src/Bootloader.c **** 
   5:src/Bootloader.c **** #include "Bootloader.h"
   6:src/Bootloader.c **** 
   7:src/Bootloader.c **** STATIC CONST CHAR16 AppleFirmwareVendor[6] = L"Apple";
   8:src/Bootloader.c **** UINT8 IsApple = 0;
   9:src/Bootloader.c **** 
  10:src/Bootloader.c **** STATIC EFI_STATUS ShowWelcomeAndConfirm(VOID);
  11:src/Bootloader.c **** EFI_STATUS RunMyNameGame(GPU_CONFIG *Graphics);
  12:src/Bootloader.c **** 
  13:src/Bootloader.c **** //=================================================================================================
  14:src/Bootloader.c **** //  efi_main: Main Function
  15:src/Bootloader.c **** //=================================================================================================
  16:src/Bootloader.c **** 
  17:src/Bootloader.c **** EFI_STATUS efi_main(EFI_HANDLE ImageHandle, EFI_SYSTEM_TABLE *SystemTable)
  18:src/Bootloader.c **** {
  19:src/Bootloader.c ****   InitializeLib(ImageHandle, SystemTable);
  20:src/Bootloader.c **** 
  21:src/Bootloader.c ****   EFI_STATUS Status;
  22:src/Bootloader.c **** 
  23:src/Bootloader.c ****   // Clear text console
  24:src/Bootloader.c ****   Status = SystemTable->ConOut->ClearScreen(SystemTable->ConOut);
  25:src/Bootloader.c ****   if(EFI_ERROR(Status))
  26:src/Bootloader.c ****   {
  27:src/Bootloader.c ****     Print(L"NOTE: Could not clear the screen.\r\n");
  28:src/Bootloader.c ****   }
  29:src/Bootloader.c **** 
  30:src/Bootloader.c **** #ifdef DISABLE_UEFI_WATCHDOG_TIMER
  31:src/Bootloader.c ****   Status = BS->SetWatchdogTimer(0, 0, 0, NULL);
  32:src/Bootloader.c ****   if(EFI_ERROR(Status))
  33:src/Bootloader.c ****   {
  34:src/Bootloader.c ****     Print(L"Error stopping watchdog timer.\r\n");
  35:src/Bootloader.c ****   }
  36:src/Bootloader.c **** #endif
  37:src/Bootloader.c **** 
  38:src/Bootloader.c ****   // Macs sometimes need explicit switch to text mode
  39:src/Bootloader.c ****   if(compare(ST->FirmwareVendor, AppleFirmwareVendor, 6))
  40:src/Bootloader.c ****   {
  41:src/Bootloader.c ****     IsApple = 1;
  42:src/Bootloader.c **** 
  43:src/Bootloader.c ****     EFI_CONSOLE_CONTROL_PROTOCOL *ConsoleMode = NULL;
  44:src/Bootloader.c ****     Status = LibLocateProtocol(&ConsoleControlProtocol, (VOID**)&ConsoleMode);
  45:src/Bootloader.c **** 
  46:src/Bootloader.c ****     if(!EFI_ERROR(Status) && ConsoleMode != NULL)
  47:src/Bootloader.c ****     {
  48:src/Bootloader.c ****       EFI_CONSOLE_CONTROL_SCREEN_MODE Current_Mode;
  49:src/Bootloader.c ****       ConsoleMode->GetMode(ConsoleMode, &Current_Mode, NULL, NULL);
  50:src/Bootloader.c **** 
  51:src/Bootloader.c ****       if(Current_Mode != EfiConsoleControlScreenText)
  52:src/Bootloader.c ****       {
  53:src/Bootloader.c ****         ConsoleMode->SetMode(ConsoleMode, EfiConsoleControlScreenText);
  54:src/Bootloader.c ****       }
  55:src/Bootloader.c ****     }
  56:src/Bootloader.c ****   }
  57:src/Bootloader.c **** 
  58:src/Bootloader.c ****   // Allocate graphics config
  59:src/Bootloader.c ****   GPU_CONFIG *Graphics;
  60:src/Bootloader.c ****   Status = ST->BootServices->AllocatePool(EfiLoaderData, sizeof(GPU_CONFIG), (void**)&Graphics);
  61:src/Bootloader.c ****   if(EFI_ERROR(Status))
  62:src/Bootloader.c ****   {
  63:src/Bootloader.c ****     Print(L"Graphics AllocatePool error. 0x%llx\r\n", Status);
  64:src/Bootloader.c ****     return Status;
  65:src/Bootloader.c ****   }
  66:src/Bootloader.c **** 
  67:src/Bootloader.c ****   // Init graphics
  68:src/Bootloader.c ****   Status = InitUEFI_GOP(ImageHandle, Graphics);
  69:src/Bootloader.c ****   if(EFI_ERROR(Status))
  70:src/Bootloader.c ****   {
  71:src/Bootloader.c ****     Print(L"InitUEFI_GOP error. 0x%llx\r\n", Status);
  72:src/Bootloader.c ****     Keywait(L"\r\n");
  73:src/Bootloader.c ****     return Status;
  74:src/Bootloader.c ****   }
  75:src/Bootloader.c **** 
  76:src/Bootloader.c ****   // Back to text screen for welcome / confirmation
  77:src/Bootloader.c ****   ST->ConOut->ClearScreen(ST->ConOut);
  78:src/Bootloader.c **** 
  79:src/Bootloader.c ****   // Welcome + confirmation
  80:src/Bootloader.c ****   Status = ShowWelcomeAndConfirm();
  81:src/Bootloader.c ****   if(EFI_ERROR(Status))
  82:src/Bootloader.c ****   {
  83:src/Bootloader.c ****     Print(L"Input error. 0x%llx\r\n", Status);
  84:src/Bootloader.c ****     return Status;
  85:src/Bootloader.c ****   }
  86:src/Bootloader.c **** 
  87:src/Bootloader.c ****   if(Status == EFI_ABORTED)
  88:src/Bootloader.c ****   {
  89:src/Bootloader.c ****     ST->ConOut->ClearScreen(ST->ConOut);
  90:src/Bootloader.c ****     Print(L"My Name cancelled by user.\r\n");
  91:src/Bootloader.c ****     return EFI_SUCCESS;
  92:src/Bootloader.c ****   }
  93:src/Bootloader.c **** 
  94:src/Bootloader.c ****   // Run the game
  95:src/Bootloader.c ****   Status = RunMyNameGame(Graphics);
  96:src/Bootloader.c **** 
  97:src/Bootloader.c ****   // End message if the game returns
  98:src/Bootloader.c ****   ST->ConOut->ClearScreen(ST->ConOut);
  99:src/Bootloader.c **** 
 100:src/Bootloader.c ****   if(EFI_ERROR(Status))
 101:src/Bootloader.c ****   {
 102:src/Bootloader.c ****     Print(L"My Name ended with error. 0x%llx\r\n", Status);
 103:src/Bootloader.c ****   }
 104:src/Bootloader.c ****   else
 105:src/Bootloader.c ****   {
 106:src/Bootloader.c ****     Print(L"My Name finished.\r\n");
 107:src/Bootloader.c ****   }
 108:src/Bootloader.c **** 
 109:src/Bootloader.c ****   Keywait(L"\r\n");
 110:src/Bootloader.c ****   return Status;
 111:src/Bootloader.c **** }
 112:src/Bootloader.c **** 
