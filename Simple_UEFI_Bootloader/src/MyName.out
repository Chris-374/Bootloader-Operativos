 292:src/MyName.c  **** STATIC VOID GetRandomPosition(const DRAW_CONTEXT *Ctx, const CHAR8 *Name1, const CHAR8 *Name2, UINT
 293:src/MyName.c  **** {
 294:src/MyName.c  ****   // 1. SOLUCIÓN AL SALTO RARO AL ROTAR (Bounding Box Máximo)
 295:src/MyName.c  ****   // Medimos el texto en estado NORMAL para conocer su largo y alto absolutos.
 296:src/MyName.c  ****   TEXT_EXTENTS T1 = MeasureText5x7(Name1, Scale, TRANSFORM_NORMAL);
 297:src/MyName.c  ****   TEXT_EXTENTS T2 = MeasureText5x7(Name2, Scale, TRANSFORM_NORMAL);
 298:src/MyName.c  **** 
 299:src/MyName.c  ****   UINTN NormalW = (T1.Width > T2.Width ? T1.Width : T2.Width);
 300:src/MyName.c  ****   UINTN NormalH = T1.Height + NAME_GAP + T2.Height;
 301:src/MyName.c  **** 
 302:src/MyName.c  ****   // El tamaño máximo que puede ocupar en CUALQUIER rotación. 
 303:src/MyName.c  ****   // Esto crea un "radio" seguro para el centro.
 304:src/MyName.c  ****   UINTN MaxDim = (NormalW > NormalH) ? NormalW : NormalH;
 305:src/MyName.c  ****   UINTN HalfDim = MaxDim / 2;
 306:src/MyName.c  **** 
 307:src/MyName.c  ****   // Definimos los límites de la pantalla donde el CENTRO (X, Y) puede existir sin que
 308:src/MyName.c  ****   // ninguna esquina choque al rotar.
 309:src/MyName.c  ****   UINTN MinX = SCREEN_MARGIN + HalfDim;
 310:src/MyName.c  ****   UINTN MaxX = (Ctx->Width > (SCREEN_MARGIN + HalfDim)) ? (Ctx->Width - SCREEN_MARGIN - HalfDim) : 
 311:src/MyName.c  **** 
 312:src/MyName.c  ****   UINTN MinY = SCREEN_MARGIN + HalfDim;
 313:src/MyName.c  ****   // Restamos 50 extra abajo para proteger la barra de instrucciones
 314:src/MyName.c  ****   UINTN MaxY = (Ctx->Height > (SCREEN_MARGIN + HalfDim + 50)) ? (Ctx->Height - SCREEN_MARGIN - Half
 315:src/MyName.c  **** 
 316:src/MyName.c  ****   UINTN RangeX = (MaxX > MinX) ? (MaxX - MinX) : 1;
 317:src/MyName.c  ****   UINTN RangeY = (MaxY > MinY) ? (MaxY - MinY) : 1;
 318:src/MyName.c  **** 
 319:src/MyName.c  ****   // 2. SOLUCIÓN AL "FALSO RANDOM" (Generador pseudoaleatorio con estado estático)
 320:src/MyName.c  ****   STATIC UINT32 RngState = 0;
 321:src/MyName.c  **** 
 322:src/MyName.c  ****   // Inicializar la semilla solo la primera vez que arranca el bootloader
 323:src/MyName.c  ****   if (RngState == 0)
 324:src/MyName.c  ****   {
 325:src/MyName.c  ****     EFI_TIME Now;
 326:src/MyName.c  ****     if (!EFI_ERROR(RT->GetTime(&Now, NULL)))
 327:src/MyName.c  ****     {
 328:src/MyName.c  ****       // Mezclamos todas las variables de tiempo usando XOR para mayor entropía
 329:src/MyName.c  ****       RngState = Now.Nanosecond ^ (Now.Second << 8) ^ (Now.Minute << 16) ^ (Now.Hour << 24) ^ 0x1A2
 330:src/MyName.c  ****     }
 331:src/MyName.c  ****     // Si por alguna razón UEFI falla en dar la hora, usamos una semilla por defecto
 332:src/MyName.c  ****     if (RngState == 0) RngState = 0x9E3779B9; 
 333:src/MyName.c  ****   }
 334:src/MyName.c  **** 
 335:src/MyName.c  ****   // Avanzamos la fórmula matemática para obtener el X
 336:src/MyName.c  ****   RngState = (RngState * 1103515245 + 12345) & 0x7FFFFFFF;
 337:src/MyName.c  ****   UINT32 RandX = RngState;
 338:src/MyName.c  **** 
 339:src/MyName.c  ****   // Avanzamos la fórmula de nuevo para obtener el Y
 340:src/MyName.c  ****   RngState = (RngState * 1103515245 + 12345) & 0x7FFFFFFF;
 341:src/MyName.c  ****   UINT32 RandY = RngState;
 342:src/MyName.c  **** 
 343:src/MyName.c  ****   *OutX = (INTN)(MinX + (RandX % RangeX));
 344:src/MyName.c  ****   *OutY = (INTN)(MinY + (RandY % RangeY));
 345:src/MyName.c  **** }
