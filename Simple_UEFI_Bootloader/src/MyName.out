 227:src/MyName.c  **** 
 228:src/MyName.c  **** STATIC VOID DrawScene(const DRAW_CONTEXT *Ctx, const CHAR8 *Name1, const CHAR8 *Name2, INTN X, INTN
 229:src/MyName.c  **** {
 230:src/MyName.c  ****     ClearScreenColor(Ctx, BG_R, BG_G, BG_B);
 231:src/MyName.c  **** 
 232:src/MyName.c  ****     TEXT_EXTENTS T1 = MeasureText5x7(Name1, LETTER_SCALE, Transform);
 233:src/MyName.c  ****     TEXT_EXTENTS T2 = MeasureText5x7(Name2, LETTER_SCALE, Transform);
 234:src/MyName.c  **** 
 235:src/MyName.c  ****     UINTN TotalW = (T1.Width > T2.Width ? T1.Width : T2.Width);
 236:src/MyName.c  ****     UINTN TotalH = T1.Height + NAME_GAP + T2.Height;
 237:src/MyName.c  **** 
 238:src/MyName.c  ****     UINTN BoxW = TotalW + 40;
 239:src/MyName.c  ****     UINTN BoxH = TotalH + 40;
 240:src/MyName.c  **** 
 241:src/MyName.c  ****     INTN BoxX = ((INTN)Ctx->Width - (INTN)BoxW) / 2;
 242:src/MyName.c  ****     INTN BoxY = ((INTN)Ctx->Height - (INTN)BoxH) / 2;
 243:src/MyName.c  **** 
 244:src/MyName.c  ****     FillRect(Ctx, BoxX, BoxY, BoxW, BoxH, 40, 40, 70);
 245:src/MyName.c  ****     FillRect(Ctx, BoxX + 6, BoxY + 6, BoxW - 12, BoxH - 12, BG_R, BG_G, BG_B);
 246:src/MyName.c  **** 
 247:src/MyName.c  ****     //
 248:src/MyName.c  ****     // Recentrar el bloque completo usando X,Y como centro aproximado
 249:src/MyName.c  ****     //
 250:src/MyName.c  ****     INTN StartX = X - ((INTN)TotalW / 2);
 251:src/MyName.c  ****     INTN StartY = Y - ((INTN)TotalH / 2);
 252:src/MyName.c  **** 
 253:src/MyName.c  ****     //
 254:src/MyName.c  ****     // Mantenerlo dentro de pantalla
 255:src/MyName.c  ****     //
 256:src/MyName.c  ****     if(StartX < SCREEN_MARGIN) StartX = SCREEN_MARGIN;
 257:src/MyName.c  ****     if(StartY < SCREEN_MARGIN) StartY = SCREEN_MARGIN;
 258:src/MyName.c  **** 
 259:src/MyName.c  ****     if(StartX + (INTN)TotalW >= (INTN)Ctx->Width - SCREEN_MARGIN)
 260:src/MyName.c  ****         StartX = (INTN)Ctx->Width - SCREEN_MARGIN - (INTN)TotalW;
 261:src/MyName.c  **** 
 262:src/MyName.c  ****     if(StartY + (INTN)TotalH >= (INTN)Ctx->Height - SCREEN_MARGIN - 50)
 263:src/MyName.c  ****         StartY = (INTN)Ctx->Height - SCREEN_MARGIN - 50 - (INTN)TotalH;
 264:src/MyName.c  **** 
