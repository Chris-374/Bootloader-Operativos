 505:src/MyName.c  **** STATIC VOID FillRect(const DRAW_CONTEXT *Ctx, INTN X, INTN Y, UINTN W, UINTN H, UINT8 R, UINT8 G, U
 506:src/MyName.c  **** {
 507:src/MyName.c  ****   UINT32 Packed = PackColor(Ctx, R, G, B);
 508:src/MyName.c  **** 
