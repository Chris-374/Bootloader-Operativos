 123:src/MyName.c  **** EFI_STATUS RunMyNameGame(GPU_CONFIG *Graphics)
 124:src/MyName.c  **** {
 125:src/MyName.c  ****   if(Graphics == NULL)
 126:src/MyName.c  ****   {
 127:src/MyName.c  ****     return EFI_INVALID_PARAMETER;
 128:src/MyName.c  ****   }
 129:src/MyName.c  **** 
 130:src/MyName.c  ****   if(Graphics->NumberOfFrameBuffers == 0)
 131:src/MyName.c  ****   {
 132:src/MyName.c  ****     return EFI_NOT_FOUND;
 133:src/MyName.c  ****   }
 134:src/MyName.c  **** 
 135:src/MyName.c  ****   EFI_GRAPHICS_OUTPUT_PROTOCOL_MODE *Mode = &Graphics->GPUArray[0];
 136:src/MyName.c  ****   if(Mode->Info == NULL || Mode->FrameBufferBase == 0)
 137:src/MyName.c  ****   {
 138:src/MyName.c  ****     return EFI_NOT_READY;
 139:src/MyName.c  ****   }
 140:src/MyName.c  **** 
 141:src/MyName.c  ****   DRAW_CONTEXT Ctx;
 142:src/MyName.c  ****   Ctx.Width = Mode->Info->HorizontalResolution;
 143:src/MyName.c  ****   Ctx.Height = Mode->Info->VerticalResolution;
 144:src/MyName.c  ****   Ctx.PixelsPerScanLine = Mode->Info->PixelsPerScanLine;
 145:src/MyName.c  ****   Ctx.PixelFormat = Mode->Info->PixelFormat;
 146:src/MyName.c  ****   Ctx.PixelInfo = Mode->Info->PixelInformation;
 147:src/MyName.c  ****   Ctx.FrameBuffer = (UINT32*)(UINTN)Mode->FrameBufferBase;
 148:src/MyName.c  **** 
 149:src/MyName.c  ****   MYNAME_TRANSFORM Transform = TRANSFORM_NORMAL;
 150:src/MyName.c  ****   INTN PosX = 0;
 151:src/MyName.c  ****   INTN PosY = 0;
 152:src/MyName.c  **** 
 153:src/MyName.c  ****   GetRandomPosition(&Ctx, NAME_1, NAME_2, LETTER_SCALE, Transform, &PosX, &PosY);
 154:src/MyName.c  ****   DrawScene(&Ctx, NAME_1, NAME_2, PosX, PosY, Transform);
 155:src/MyName.c  **** 
 156:src/MyName.c  ****   while(1)
 157:src/MyName.c  ****   {
 158:src/MyName.c  ****     EFI_INPUT_KEY Key;
 159:src/MyName.c  ****     EFI_STATUS Status = WaitKey(&Key);
 160:src/MyName.c  ****     if(EFI_ERROR(Status))
 161:src/MyName.c  ****     {
 162:src/MyName.c  ****       return Status;
 163:src/MyName.c  ****     }
 164:src/MyName.c  **** 
 165:src/MyName.c  ****     if(Key.ScanCode == SCAN_ESC)
 166:src/MyName.c  ****     {
 167:src/MyName.c  ****       return EFI_SUCCESS;
 168:src/MyName.c  ****     }
 169:src/MyName.c  **** 
 170:src/MyName.c  ****     if(Key.UnicodeChar == L'r' || Key.UnicodeChar == L'R')
 171:src/MyName.c  ****     {
 172:src/MyName.c  ****       Transform = TRANSFORM_NORMAL;
 173:src/MyName.c  ****       GetRandomPosition(&Ctx, NAME_1, NAME_2, LETTER_SCALE, Transform, &PosX, &PosY);
 174:src/MyName.c  ****       DrawScene(&Ctx, NAME_1, NAME_2, PosX, PosY, Transform);
 175:src/MyName.c  ****       continue;
 176:src/MyName.c  ****     }
 177:src/MyName.c  **** 
 178:src/MyName.c  ****     if(Key.ScanCode == SCAN_LEFT)
 179:src/MyName.c  ****     {
 180:src/MyName.c  ****       Transform = TRANSFORM_ROT_LEFT_90;
 181:src/MyName.c  ****       DrawScene(&Ctx, NAME_1, NAME_2, PosX, PosY, Transform);
 182:src/MyName.c  ****       continue;
 183:src/MyName.c  ****     }
 184:src/MyName.c  **** 
 185:src/MyName.c  ****     if(Key.ScanCode == SCAN_RIGHT)
 186:src/MyName.c  ****     {
 187:src/MyName.c  ****       Transform = TRANSFORM_ROT_RIGHT_90;
 188:src/MyName.c  ****       DrawScene(&Ctx, NAME_1, NAME_2, PosX, PosY, Transform);
 189:src/MyName.c  ****       continue;
 190:src/MyName.c  ****     }
 191:src/MyName.c  **** 
 192:src/MyName.c  ****     if(Key.ScanCode == SCAN_UP)
 193:src/MyName.c  ****     {
 194:src/MyName.c  ****       Transform = TRANSFORM_FLIP_VERTICAL;
 195:src/MyName.c  ****       DrawScene(&Ctx, NAME_1, NAME_2, PosX, PosY, Transform);
 196:src/MyName.c  ****       continue;
 197:src/MyName.c  ****     }
 198:src/MyName.c  **** 
 199:src/MyName.c  ****     if(Key.ScanCode == SCAN_DOWN)
 200:src/MyName.c  ****     {
 201:src/MyName.c  ****       Transform = TRANSFORM_ROT_180;
 202:src/MyName.c  ****       DrawScene(&Ctx, NAME_1, NAME_2, PosX, PosY, Transform);
 203:src/MyName.c  ****       continue;
 204:src/MyName.c  ****     }
 205:src/MyName.c  ****   }
 206:src/MyName.c  **** }
