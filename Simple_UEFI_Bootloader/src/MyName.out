 428:src/MyName.c  **** STATIC VOID DrawGlyph5x7(const DRAW_CONTEXT *Ctx, CHAR8 Ch, INTN X, INTN Y, UINTN Scale, MYNAME_TRA
 429:src/MyName.c  **** {
 430:src/MyName.c  ****   const FONT5X7 *Glyph = FindGlyph(Ch);
 431:src/MyName.c  ****   if(Glyph == NULL)
 432:src/MyName.c  ****   {
 433:src/MyName.c  ****     return;
 434:src/MyName.c  ****   }
 435:src/MyName.c  **** 
 436:src/MyName.c  ****   const UINTN SrcW = 5;
 437:src/MyName.c  ****   const UINTN SrcH = 7;
 438:src/MyName.c  **** 
 439:src/MyName.c  ****   for(UINTN Row = 0; Row < SrcH; Row++)
 440:src/MyName.c  ****   {
 441:src/MyName.c  ****     UINT8 Bits = Glyph->rows[Row];
 442:src/MyName.c  **** 
 443:src/MyName.c  ****     for(UINTN Col = 0; Col < SrcW; Col++)
 444:src/MyName.c  ****     {
 445:src/MyName.c  ****       if((Bits & (1 << (4 - Col))) == 0)
 446:src/MyName.c  ****       {
 447:src/MyName.c  ****         continue;
 448:src/MyName.c  ****       }
 449:src/MyName.c  **** 
 450:src/MyName.c  ****       INTN DX = 0;
 451:src/MyName.c  ****       INTN DY = 0;
 452:src/MyName.c  **** 
 453:src/MyName.c  ****       switch(Transform)
 454:src/MyName.c  ****       {
 455:src/MyName.c  ****         case TRANSFORM_NORMAL:
 456:src/MyName.c  ****           DX = (INTN)Col;
 457:src/MyName.c  ****           DY = (INTN)Row;
 458:src/MyName.c  ****           break;
 459:src/MyName.c  **** 
 460:src/MyName.c  ****         case TRANSFORM_ROT_LEFT_90:
 461:src/MyName.c  ****           DX = (INTN)Row;
 462:src/MyName.c  ****           DY = (INTN)(SrcW - 1 - Col);
 463:src/MyName.c  ****           break;
 464:src/MyName.c  **** 
 465:src/MyName.c  ****         case TRANSFORM_ROT_RIGHT_90:
 466:src/MyName.c  ****           DX = (INTN)(SrcH - 1 - Row);
 467:src/MyName.c  ****           DY = (INTN)Col;
 468:src/MyName.c  ****           break;
 469:src/MyName.c  **** 
 470:src/MyName.c  ****         case TRANSFORM_FLIP_VERTICAL:
 471:src/MyName.c  ****           DX = (INTN)Col;
 472:src/MyName.c  ****           DY = (INTN)(SrcH - 1 - Row);
 473:src/MyName.c  ****           break;
 474:src/MyName.c  **** 
 475:src/MyName.c  ****         case TRANSFORM_ROT_180:
 476:src/MyName.c  ****           DX = (INTN)(SrcW - 1 - Col);
 477:src/MyName.c  ****           DY = (INTN)(SrcH - 1 - Row);
 478:src/MyName.c  ****           break;
 479:src/MyName.c  **** 
 480:src/MyName.c  ****         default:
 481:src/MyName.c  ****           DX = (INTN)Col;
 482:src/MyName.c  ****           DY = (INTN)Row;
 483:src/MyName.c  ****           break;
 484:src/MyName.c  ****       }
 485:src/MyName.c  **** 
 486:src/MyName.c  ****       FillRect(Ctx, X + DX * (INTN)Scale, Y + DY * (INTN)Scale, Scale, Scale, R, G, B);
 487:src/MyName.c  ****     }
 488:src/MyName.c  ****   }
 489:src/MyName.c  **** }
