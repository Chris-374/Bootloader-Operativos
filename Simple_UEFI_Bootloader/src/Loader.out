 229:src/Loader.c  **** 
 230:src/Loader.c  **** */
 231:src/Loader.c  ****   Print(L"Created: %02hhu/%02hhu/%04hu - %02hhu:%02hhu:%02hhu.%u\r\n", Txt_FileInfo->CreateTime.Mon
 232:src/Loader.c  ****   Print(L"Last Modified: %02hhu/%02hhu/%04hu - %02hhu:%02hhu:%02hhu.%u\r\n", Txt_FileInfo->Modifica
 233:src/Loader.c  ****   Keywait(L"\0");
