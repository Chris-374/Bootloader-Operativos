 236:src/Loader.c  ****   // Read text file into memory now that we know the file size
 237:src/Loader.c  ****   CHAR16 * KernelcmdArray;
 238:src/Loader.c  ****   // Reserve memory for text file
 239:src/Loader.c  ****   GoTimeStatus = ST->BootServices->AllocatePool(EfiBootServicesData, Txt_FileInfo->FileSize, (void*
 240:src/Loader.c  ****   if(EFI_ERROR(GoTimeStatus))
 241:src/Loader.c  ****   {
 242:src/Loader.c  ****     Print(L"KernelcmdArray AllocatePool error. 0x%llx\r\n", GoTimeStatus);
 243:src/Loader.c  ****     return GoTimeStatus;
 244:src/Loader.c  ****   }
 245:src/Loader.c  **** 
 246:src/Loader.c  ****   // Actually read the file
 247:src/Loader.c  ****   GoTimeStatus = KernelcmdFile->Read(KernelcmdFile, &Txt_FileInfo->FileSize, KernelcmdArray);
 248:src/Loader.c  ****   if(EFI_ERROR(GoTimeStatus))
 249:src/Loader.c  ****   {
 250:src/Loader.c  ****     Print(L"KernelcmdArray read error. 0x%llx\r\n", GoTimeStatus);
 251:src/Loader.c  ****     return GoTimeStatus;
 252:src/Loader.c  ****   }
 253:src/Loader.c  **** 
 254:src/Loader.c  **** #ifdef LOADER_DEBUG_ENABLED
 255:src/Loader.c  ****   Keywait(L"KernelcmdFile read into memory.\r\n");
 256:src/Loader.c  **** #endif
 257:src/Loader.c  **** 
 258:src/Loader.c  ****   // UTF-16 format check
 259:src/Loader.c  ****   UINT16 BOM_check = UTF16_BOM_LE;
 260:src/Loader.c  ****   if(!compare(KernelcmdArray, &BOM_check, 2))
 261:src/Loader.c  ****   {
 262:src/Loader.c  ****     BOM_check = UTF16_BOM_BE; // Check endianness
 263:src/Loader.c  ****     if(compare(KernelcmdArray, &BOM_check, 2))
 264:src/Loader.c  ****     {
 265:src/Loader.c  ****       Print(L"Error: Kernel64.txt has the wrong endianness for this system.\r\n");
 266:src/Loader.c  ****     }
 267:src/Loader.c  ****     else // Probably missing a BOM
 268:src/Loader.c  ****     {
 269:src/Loader.c  ****       Print(L"Error: Kernel64.txt not formatted as UTF-16/UCS-2 with BOM.\r\n\n");
 270:src/Loader.c  ****       Print(L"Q: What is a BOM?\r\n\n");
 271:src/Loader.c  ****       Print(L"A: The BOM (Byte Order Mark) is a 2-byte identification sequence\r\n");
 272:src/Loader.c  ****       Print(L"(U+FEFF) at the start of a UTF16/UCS-2-encoded file.\r\n");
 273:src/Loader.c  ****       Print(L"Unfortunately not all editors add it in, and without\r\n");
 274:src/Loader.c  ****       Print(L"a BOM present programs like this one cannot easily tell that a\r\n");
 275:src/Loader.c  ****       Print(L"text file is encoded in UTF16/UCS-2.\r\n\n");
 276:src/Loader.c  ****       Print(L"Windows Notepad & Wordpad and Linux gedit & xed all add BOMs when\r\n");
 277:src/Loader.c  ****       Print(L"saving files as .txt with encoding set to \"Unicode\" (Windows)\r\n");
 278:src/Loader.c  ****       Print(L"or \"UTF16\" (Linux), so use one of them to make Kernel64.txt.\r\n\n");
 279:src/Loader.c  ****     }
 280:src/Loader.c  ****     Keywait(L"Please fix the file and try again.\r\n");
 281:src/Loader.c  ****     return GoTimeStatus;
 282:src/Loader.c  ****   }
 283:src/Loader.c  ****   // Parse Kernel64.txt file for location of kernel image and command line
 284:src/Loader.c  ****   // Kernel image location line will be of format e.g. \EFI\ubuntu\vmlinuz.efi followed by \n or \r
 285:src/Loader.c  ****   // Command line will just go until the next \n or \r\n, and should just be loaded as a UTF-16 str
 286:src/Loader.c  **** 
 287:src/Loader.c  ****   // Get size of kernel image path & command line and populate the data retention variables
 288:src/Loader.c  ****   UINT64 FirstLineLength = 0;
 289:src/Loader.c  ****   UINT64 KernelPathSize = 0;
 290:src/Loader.c  **** 
 291:src/Loader.c  ****   for(UINT64 i = 1; i < ((Txt_FileInfo->FileSize) >> 1); i++) // i starts at 1 to skip the BOM, ((T
 292:src/Loader.c  ****   {
 293:src/Loader.c  ****     if(KernelcmdArray[i] == L'\n')
 294:src/Loader.c  ****     {
 295:src/Loader.c  ****       // Account for the L'\n'
 296:src/Loader.c  ****       FirstLineLength = i + 1;
 297:src/Loader.c  ****       // The extra +1 is to start the command line parse in the correct place
 298:src/Loader.c  ****       break;
 299:src/Loader.c  ****     }
 300:src/Loader.c  ****     else if(KernelcmdArray[i] == L'\r')
 301:src/Loader.c  ****     {
 302:src/Loader.c  ****       // There'll be a \n after the \r
 303:src/Loader.c  ****       FirstLineLength = i + 1 + 1;
 304:src/Loader.c  ****       // The extra +1 is to start the command line parse in the correct place
 305:src/Loader.c  ****       break;
 306:src/Loader.c  ****     }
 307:src/Loader.c  **** 
 308:src/Loader.c  ****     if(KernelcmdArray[i] != L' ') // There might be an errant space or two. Ignore them.
 309:src/Loader.c  ****     {
 310:src/Loader.c  ****       KernelPathSize++;
 311:src/Loader.c  ****     }
 312:src/Loader.c  ****   }
 313:src/Loader.c  ****   UINT64 KernelPathLen = KernelPathSize; // Need this for later
 314:src/Loader.c  ****   // Need to add null terminator. Multiply by size of CHAR16 (2 bytes) to get size.
 315:src/Loader.c  ****   KernelPathSize = (KernelPathSize + 1) << 1; // (KernelPathSize + 1) * sizeof(CHAR16)
 316:src/Loader.c  **** 
 317:src/Loader.c  **** #ifdef LOADER_DEBUG_ENABLED
 318:src/Loader.c  ****   Print(L"KernelPathSize: %llu\r\n", KernelPathSize);
 319:src/Loader.c  **** #endif
 320:src/Loader.c  **** 
 321:src/Loader.c  ****   // Command line's turn
 322:src/Loader.c  ****   UINT64 CmdlineSize = 0; // Interestingly, the Linux kernel only takes 256 to 4096 chars for load 
 323:src/Loader.c  **** 
 324:src/Loader.c  ****   for(UINT64 j = FirstLineLength; j < ((Txt_FileInfo->FileSize) >> 1); j++)
 325:src/Loader.c  ****   {
 326:src/Loader.c  ****     if((KernelcmdArray[j] == L'\n') || (KernelcmdArray[j] == L'\r')) // Reached the end of the line
 327:src/Loader.c  ****     {
 328:src/Loader.c  ****       break;
 329:src/Loader.c  ****     }
 330:src/Loader.c  **** 
 331:src/Loader.c  ****     CmdlineSize++;
 332:src/Loader.c  ****   }
 333:src/Loader.c  ****   UINT64 CmdlineLen = CmdlineSize; // Need this for later
 334:src/Loader.c  ****   // Need to add null terminator. Multiply by size of CHAR16 (2 bytes) to get size.
 335:src/Loader.c  ****   CmdlineSize = (CmdlineSize + 1) << 1; // (CmdlineSize + 1) * sizeof(CHAR16)
 336:src/Loader.c  **** 
 337:src/Loader.c  **** #ifdef LOADER_DEBUG_ENABLED
 338:src/Loader.c  ****   Print(L"CmdlineSize: %llu\r\n", CmdlineSize);
 339:src/Loader.c  **** #endif
 340:src/Loader.c  **** 
 341:src/Loader.c  ****   CHAR16 * KernelPath; // EFI Kernel file's Path
 342:src/Loader.c  ****   GoTimeStatus = ST->BootServices->AllocatePool(EfiLoaderData, KernelPathSize, (void**)&KernelPath)
 343:src/Loader.c  ****   if(EFI_ERROR(GoTimeStatus))
 344:src/Loader.c  ****   {
 345:src/Loader.c  ****     Print(L"KernelPath AllocatePool error. 0x%llx\r\n", GoTimeStatus);
 346:src/Loader.c  ****     return GoTimeStatus;
 347:src/Loader.c  ****   }
 348:src/Loader.c  **** 
 349:src/Loader.c  ****   CHAR16 * Cmdline; // Command line to pass to EFI kernel
 350:src/Loader.c  ****   GoTimeStatus = ST->BootServices->AllocatePool(EfiLoaderData, CmdlineSize, (void**)&Cmdline);
 351:src/Loader.c  ****   if(EFI_ERROR(GoTimeStatus))
 352:src/Loader.c  ****   {
 353:src/Loader.c  ****     Print(L"Cmdline AllocatePool error. 0x%llx\r\n", GoTimeStatus);
 354:src/Loader.c  ****     return GoTimeStatus;
 355:src/Loader.c  ****   }
 356:src/Loader.c  **** 
 357:src/Loader.c  ****   for(UINT64 i = 1; i < FirstLineLength; i++)
 358:src/Loader.c  ****   {
 359:src/Loader.c  ****     if((KernelcmdArray[i] == L'\n') || (KernelcmdArray[i] == L'\r'))
 360:src/Loader.c  ****     {
 361:src/Loader.c  ****       break;
 362:src/Loader.c  ****     }
 363:src/Loader.c  **** 
 364:src/Loader.c  ****     if(KernelcmdArray[i] != L' ') // There might be an errant space or two. Ignore them.
 365:src/Loader.c  ****     {
 366:src/Loader.c  ****       KernelPath[i-1] = KernelcmdArray[i]; // i-1 to ignore the 2 bytes of UTF-16 BOM
 367:src/Loader.c  ****     }
 368:src/Loader.c  ****   }
 369:src/Loader.c  ****   KernelPath[KernelPathLen] = L'\0'; // Need to null-terminate this string
 370:src/Loader.c  **** 
 371:src/Loader.c  ****   // Command line's turn
 372:src/Loader.c  ****   for(UINT64 j = FirstLineLength; j < ((Txt_FileInfo->FileSize) >> 1); j++)
 373:src/Loader.c  ****   {
 374:src/Loader.c  ****     if((KernelcmdArray[j] == L'\n') || (KernelcmdArray[j] == L'\r')) // Reached the end of the line
 375:src/Loader.c  ****     {
 376:src/Loader.c  ****       break;
 377:src/Loader.c  ****     }
 378:src/Loader.c  **** 
 379:src/Loader.c  ****     Cmdline[j-FirstLineLength] = KernelcmdArray[j];
 380:src/Loader.c  ****   }
 381:src/Loader.c  ****   Cmdline[CmdlineLen] = L'\0'; // Need to null-terminate this string
 382:src/Loader.c  **** 
 383:src/Loader.c  **** #ifdef LOADER_DEBUG_ENABLED
 384:src/Loader.c  ****   Print(L"Kernel image path: %s\r\nKernel image path size: %u\r\n", KernelPath, KernelPathSize);
 385:src/Loader.c  ****   Print(L"Kernel command line: %s\r\nKernel command line size: %u\r\n", Cmdline, CmdlineSize);
 386:src/Loader.c  ****   Keywait(L"Loading image... (might take a second or two after pressing a key)\r\n");
 387:src/Loader.c  **** #endif
 388:src/Loader.c  **** 
