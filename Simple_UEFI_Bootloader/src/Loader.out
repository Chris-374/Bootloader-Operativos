 219:src/Loader.c  **** /*
 220:src/Loader.c  ****   NOTE: Attributes:
 221:src/Loader.c  **** 
 222:src/Loader.c  ****   #define EFI_FILE_READ_ONLY 0x0000000000000001
 223:src/Loader.c  ****   #define EFI_FILE_HIDDEN 0x0000000000000002
 224:src/Loader.c  ****   #define EFI_FILE_SYSTEM 0x0000000000000004
