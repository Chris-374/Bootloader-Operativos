 201:src/Loader.c  ****     return GoTimeStatus;
 202:src/Loader.c  ****   }
 203:src/Loader.c  **** 
 204:src/Loader.c  ****   // Actually get the metadata
 205:src/Loader.c  ****   GoTimeStatus = KernelcmdFile->GetInfo(KernelcmdFile, &gEfiFileInfoGuid, &Txt_FileInfoSize, Txt_Fi
 206:src/Loader.c  ****   if(EFI_ERROR(GoTimeStatus))
