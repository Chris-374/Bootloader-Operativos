 399:src/Loader.c  ****   {
 400:src/Loader.c  ****     Print(L"Error freeing KernelcmdArray pool. 0x%llx\r\n", GoTimeStatus);
 401:src/Loader.c  ****     return GoTimeStatus;
 402:src/Loader.c  ****   }
