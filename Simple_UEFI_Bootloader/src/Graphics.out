1944:src/Graphics.c **** // I've seen a rogue EFI_GUID that I can't find what it's for: 39487C79-236D-4666-87E5-09547CAAE1BC
1945:src/Graphics.c **** // In "GUID Format" it's this: {0x39487c79, 0x236d, 0x4666, {0x87, 0xe5, 0x09, 0x54, 0x7c, 0xaa, 0x
1946:src/Graphics.c **** 
1947:src/Graphics.c **** EFI_STATUS WhatProtocols(EFI_HANDLE * HandleArray, UINTN NumHandlesInHandleArray)
1948:src/Graphics.c **** {
1949:src/Graphics.c ****   UINTN NumInHandle = 0;
1950:src/Graphics.c ****   EFI_GUID ** ProtocolGUIDList;
1951:src/Graphics.c **** 
1952:src/Graphics.c ****   EFI_STATUS GOPStatus = EFI_SUCCESS;
1953:src/Graphics.c **** 
1954:src/Graphics.c ****   CHAR8 LanguageToUse[6] = {'e','n','-','U','S','\0'};
1955:src/Graphics.c ****   CHAR8 LanguageToUse2[3] = {'e','n','\0'};
1956:src/Graphics.c ****   CHAR8 LanguageToUse3[4] = {'e','n','g','\0'};
1957:src/Graphics.c **** 
1958:src/Graphics.c ****   CHAR16 DefaultDriverDisplayName[15] = L"No Driver Name";
1959:src/Graphics.c **** 
1960:src/Graphics.c ****   CHAR16 * DriverDisplayName = DefaultDriverDisplayName;
1961:src/Graphics.c **** 
1962:src/Graphics.c ****   for(UINT64 j = 0; j < NumHandlesInHandleArray; j++)
1963:src/Graphics.c ****   {
1964:src/Graphics.c ****     Print(L"Handle %llu: 0x%llx\r\n", j, HandleArray[j]);
1965:src/Graphics.c ****     if(HandleArray[j] == NULL)
1966:src/Graphics.c ****     {
1967:src/Graphics.c ****       Print(L"Null Handle\r\n");
1968:src/Graphics.c ****       continue;
1969:src/Graphics.c ****     }
1970:src/Graphics.c **** 
1971:src/Graphics.c ****     GOPStatus = BS->ProtocolsPerHandle(HandleArray[j], &ProtocolGUIDList, &NumInHandle);
1972:src/Graphics.c ****     if(EFI_ERROR(GOPStatus))
1973:src/Graphics.c ****     {
1974:src/Graphics.c ****       Print(L"ProtocolsPerHandle error. 0x%llx\r\n", GOPStatus);
1975:src/Graphics.c ****       return GOPStatus;
1976:src/Graphics.c ****     }
1977:src/Graphics.c **** 
1978:src/Graphics.c ****     for(UINT64 q = 0; q < NumInHandle; q++)
1979:src/Graphics.c ****     {
1980:src/Graphics.c ****       Print(L"%08x-%04x-%04x-%02x%02x-%02x%02x%02x%02x%02x%02x: ",
1981:src/Graphics.c ****           ProtocolGUIDList[q]->Data1,
1982:src/Graphics.c ****           ProtocolGUIDList[q]->Data2,
1983:src/Graphics.c ****           ProtocolGUIDList[q]->Data3,
1984:src/Graphics.c ****           ProtocolGUIDList[q]->Data4[0],
1985:src/Graphics.c ****           ProtocolGUIDList[q]->Data4[1],
