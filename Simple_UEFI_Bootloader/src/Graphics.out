   1:src/Graphics.c **** //=================================================================================================
   2:src/Graphics.c **** //  Simple UEFI Bootloader: Graphics Functions
   3:src/Graphics.c **** //=================================================================================================
   4:src/Graphics.c **** //
   5:src/Graphics.c **** // Version 2.3
   6:src/Graphics.c **** //
   7:src/Graphics.c **** // Author:
   8:src/Graphics.c **** //  KNNSpeed
   9:src/Graphics.c **** //
  10:src/Graphics.c **** // Source Code:
  11:src/Graphics.c **** //  https://github.com/KNNSpeed/Simple-UEFI-Bootloader
  12:src/Graphics.c **** //
  13:src/Graphics.c **** // This file contains the graphics setup code.
  14:src/Graphics.c **** //
  15:src/Graphics.c **** 
  16:src/Graphics.c **** #include "Bootloader.h"
  17:src/Graphics.c **** 
  18:src/Graphics.c **** #define GPU_MENU_TIMEOUT_SECONDS 90
  19:src/Graphics.c **** 
  20:src/Graphics.c **** STATIC EFI_STATUS apple_set_os(VOID);
  21:src/Graphics.c **** 
  22:src/Graphics.c **** //=================================================================================================
  23:src/Graphics.c **** //  InitUEFI_GOP: Graphics Initialization
  24:src/Graphics.c **** //=================================================================================================
  25:src/Graphics.c **** //
  26:src/Graphics.c **** // Determine the UEFI-provided graphical capabilities of the machine and set the desired output mod
  27:src/Graphics.c **** // Writes a GPU_CONFIG structure, which contains an array of EFI_GRAPHICS_OUTPUT_PROTOCOL_MODE stru
  28:src/Graphics.c **** /*
  29:src/Graphics.c ****   typedef struct {
  30:src/Graphics.c ****     EFI_GRAPHICS_OUTPUT_PROTOCOL_MODE  *GPUArray;             // An array of EFI_GRAPHICS_OUTPUT_PR
  31:src/Graphics.c ****     UINT64                              NumberOfFrameBuffers; // The number of structs in the array
  32:src/Graphics.c ****   } GPU_CONFIG;
  33:src/Graphics.c **** */
  34:src/Graphics.c **** // The GPUArray pointer points to the base address of an array of these structures:
  35:src/Graphics.c **** /*
  36:src/Graphics.c ****   typedef struct {
  37:src/Graphics.c ****     UINT32                                 MaxMode;
  38:src/Graphics.c ****     UINT32                                 Mode;
  39:src/Graphics.c ****     EFI_GRAPHICS_OUTPUT_MODE_INFORMATION   *Info;
  40:src/Graphics.c ****     UINTN                                  SizeOfInfo;
  41:src/Graphics.c ****     EFI_PHYSICAL_ADDRESS                   FrameBufferBase;
  42:src/Graphics.c ****     UINTN                                  FrameBufferSize;
  43:src/Graphics.c ****   } EFI_GRAPHICS_OUTPUT_PROTOCOL_MODE;
  44:src/Graphics.c **** */
  45:src/Graphics.c **** // Various parameters within this structure are defined like so:
  46:src/Graphics.c **** /*
  47:src/Graphics.c ****   typedef struct {
  48:src/Graphics.c ****     UINT32                     Version;
  49:src/Graphics.c ****     UINT32                     HorizontalResolution;
  50:src/Graphics.c ****     UINT32                     VerticalResolution;
  51:src/Graphics.c ****     EFI_GRAPHICS_PIXEL_FORMAT  PixelFormat;            // 0 - 4
  52:src/Graphics.c ****     EFI_PIXEL_BITMASK          PixelInformation;
  53:src/Graphics.c ****     UINT32                     PixelsPerScanLine;
  54:src/Graphics.c ****   } EFI_GRAPHICS_OUTPUT_MODE_INFORMATION;
  55:src/Graphics.c **** 
  56:src/Graphics.c ****   typedef enum {
  57:src/Graphics.c ****     PixelRedGreenBlueReserved8BitPerColor,   // 0
  58:src/Graphics.c ****     PixelBlueGreenRedReserved8BitPerColor,   // 1
  59:src/Graphics.c ****     PixelBitMask,                            // 2
  60:src/Graphics.c ****     PixelBltOnly,                            // 3
  61:src/Graphics.c ****     PixelFormatMax                           // 4
  62:src/Graphics.c ****   } EFI_GRAPHICS_PIXEL_FORMAT;
  63:src/Graphics.c **** 
  64:src/Graphics.c ****   typedef struct {
  65:src/Graphics.c ****     UINT32            RedMask;
  66:src/Graphics.c ****     UINT32            GreenMask;
  67:src/Graphics.c ****     UINT32            BlueMask;
  68:src/Graphics.c ****     UINT32            ReservedMask;
  69:src/Graphics.c ****   } EFI_PIXEL_BITMASK;
  70:src/Graphics.c **** */
  71:src/Graphics.c **** //
  72:src/Graphics.c **** 
  73:src/Graphics.c **** // This array is a global variable so that it can be made static, which helps prevent a stack overf
  74:src/Graphics.c **** STATIC CONST CHAR16 PxFormats[5][17] = {
  75:src/Graphics.c ****     L"RGBReserved 8Bpp",
  76:src/Graphics.c ****     L"BGRReserved 8Bpp",
  77:src/Graphics.c ****     L"PixelBitMask    ",
  78:src/Graphics.c ****     L"PixelBltOnly    ",
  79:src/Graphics.c ****     L"PixelFormatMax  "
  80:src/Graphics.c **** };
  81:src/Graphics.c **** 
  82:src/Graphics.c **** EFI_STATUS InitUEFI_GOP(EFI_HANDLE ImageHandle, GPU_CONFIG * Graphics)
  83:src/Graphics.c **** { // Declaring a pointer only allocates 8 bytes (64-bit) for that pointer. Buffers must be manually
  84:src/Graphics.c **** 
  85:src/Graphics.c ****   Graphics->NumberOfFrameBuffers = 0;
  86:src/Graphics.c **** 
  87:src/Graphics.c ****   EFI_STATUS GOPStatus;
  88:src/Graphics.c **** 
  89:src/Graphics.c ****   UINT64 GOPInfoSize;
  90:src/Graphics.c ****   UINT32 mode;
  91:src/Graphics.c ****   UINTN NumHandlesInHandleBuffer = 0; // Number of discovered graphics handles (GPUs)
  92:src/Graphics.c ****   UINTN NumName2Handles = 0;
  93:src/Graphics.c ****   UINTN NumDevPathHandles = 0;
  94:src/Graphics.c ****   UINT64 DevNum = 0;
  95:src/Graphics.c ****   EFI_INPUT_KEY Key;
  96:src/Graphics.c **** 
  97:src/Graphics.c ****   Key.UnicodeChar = 0;
  98:src/Graphics.c **** 
  99:src/Graphics.c ****   // Vendors go all over the place with these...
 100:src/Graphics.c ****   CHAR8 LanguageToUse[6] = {'e','n','-','U','S','\0'};
 101:src/Graphics.c ****   CHAR8 LanguageToUse2[3] = {'e','n','\0'};
 102:src/Graphics.c ****   CHAR8 LanguageToUse3[4] = {'e','n','g','\0'};
 103:src/Graphics.c **** 
 104:src/Graphics.c ****   CHAR16 DefaultDriverDisplayName[15] = L"No Driver Name";
 105:src/Graphics.c ****   CHAR16 DefaultControllerDisplayName[19] = L"No Controller Name";
 106:src/Graphics.c ****   CHAR16 DefaultChildDisplayName[14] = L"No Child Name";
 107:src/Graphics.c **** 
 108:src/Graphics.c ****   CHAR16 * DriverDisplayName = DefaultDriverDisplayName;
 109:src/Graphics.c ****   CHAR16 * ControllerDisplayName = DefaultControllerDisplayName;
 110:src/Graphics.c ****   CHAR16 * ChildDisplayName = DefaultChildDisplayName;
 111:src/Graphics.c **** 
 112:src/Graphics.c ****   // Wall of Shame:
 113:src/Graphics.c ****   // Drivers of devices that improperly return GetControllerName and claim to be the controllers of
 114:src/Graphics.c ****   // You can find some of these by searching for "ppControllerName" in EDK2.
 115:src/Graphics.c **** 
 116:src/Graphics.c ****   // In the comment adjacent each driver name you'll see listed the controller name that will ruin 
 117:src/Graphics.c ****   #define NUM_ON_WALL 4
 118:src/Graphics.c **** 
 119:src/Graphics.c ****   CONST CHAR16 AmiPS2Drv[16] = L"AMI PS/2 Driver"; // L"Generic PS/2 Keyboard"
 120:src/Graphics.c ****   CONST CHAR16 AsixUSBEth10Drv[34] = L"ASIX AX88772B Ethernet Driver 1.0"; // L"ASIX AX88772B USB F
 121:src/Graphics.c ****   CONST CHAR16 SocketLayerDrv[20] = L"Socket Layer Driver"; // L"Socket Layer";
 122:src/Graphics.c ****   CONST CHAR16 Asix10100EthDrv[24] = L"AX88772 Ethernet Driver"; // L"AX88772 10/100 Ethernet"
 123:src/Graphics.c **** 
 124:src/Graphics.c ****   CONST CHAR16 * CONST Wall_of_Shame[NUM_ON_WALL] = {AmiPS2Drv, AsixUSBEth10Drv, SocketLayerDrv, As
 125:src/Graphics.c **** 
 126:src/Graphics.c ****   // End Wall_of_Shame init
 127:src/Graphics.c **** 
 128:src/Graphics.c ****   // We can pick which graphics output device we want (handy for multi-GPU setups)...
 129:src/Graphics.c ****   EFI_HANDLE *GraphicsHandles; // Array of discovered graphics handles that support the Graphics Ou
 130:src/Graphics.c ****   GOPStatus = BS->LocateHandleBuffer(ByProtocol, &GraphicsOutputProtocol, NULL, &NumHandlesInHandle
 131:src/Graphics.c ****   if(EFI_ERROR(GOPStatus))
 132:src/Graphics.c ****   {
 133:src/Graphics.c ****     Print(L"GraphicsTable LocateHandleBuffer error. 0x%llx\r\n", GOPStatus);
 134:src/Graphics.c ****     return GOPStatus;
 135:src/Graphics.c ****   }
 136:src/Graphics.c **** 
 137:src/Graphics.c ****   Print(L"\r\n");
 138:src/Graphics.c ****   if(NumHandlesInHandleBuffer == 1) // Grammar
 139:src/Graphics.c ****   {
 140:src/Graphics.c ****     Print(L"There is %llu UEFI graphics device:\r\n\n", NumHandlesInHandleBuffer);
 141:src/Graphics.c ****   }
 142:src/Graphics.c ****   else
 143:src/Graphics.c ****   {
 144:src/Graphics.c ****     Print(L"There are %llu UEFI graphics devices:\r\n\n", NumHandlesInHandleBuffer);
 145:src/Graphics.c ****   }
 146:src/Graphics.c **** 
 147:src/Graphics.c **** #ifdef GOP_DEBUG_ENABLED
 148:src/Graphics.c ****   Print(L"NameBuffer size: %llu\r\n", sizeof(CHAR16*) * NumHandlesInHandleBuffer);
 149:src/Graphics.c **** #endif
 150:src/Graphics.c **** 
