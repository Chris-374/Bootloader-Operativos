1640:src/Graphics.c **** 
1641:src/Graphics.c **** #ifdef GOP_DEBUG_ENABLED
1642:src/Graphics.c ****     Print(L"Current GOP Info Size: %llu\r\n", GOPTable->Mode->SizeOfInfo);
1643:src/Graphics.c **** #endif
1644:src/Graphics.c **** 
1645:src/Graphics.c ****     // Allocate graphics mode info
1646:src/Graphics.c ****     GOPStatus = ST->BootServices->AllocatePool(EfiLoaderData, GOPTable->Mode->SizeOfInfo, (void**)&
1647:src/Graphics.c ****     if(EFI_ERROR(GOPStatus))
1648:src/Graphics.c ****     {
1649:src/Graphics.c ****       Print(L"GOP Mode->Info AllocatePool error. 0x%llx\r\n", GOPStatus);
1650:src/Graphics.c ****       return GOPStatus;
1651:src/Graphics.c ****     }
1652:src/Graphics.c **** 
1653:src/Graphics.c **** #ifdef GOP_DEBUG_ENABLED
1654:src/Graphics.c ****     Keywait(L"Current mode info allocated.\r\n");
1655:src/Graphics.c **** #endif
1656:src/Graphics.c **** 
1657:src/Graphics.c ****     // Store graphics mode info
1658:src/Graphics.c ****     // Can't blanketly store Mode struct because Mode->Info pointer in array will get overwritten
1659:src/Graphics.c ****     Graphics->GPUArray[DevNum].MaxMode = GOPTable->Mode->MaxMode;
1660:src/Graphics.c ****     Graphics->GPUArray[DevNum].Mode = GOPTable->Mode->Mode;
1661:src/Graphics.c ****     Graphics->GPUArray[DevNum].SizeOfInfo = GOPTable->Mode->SizeOfInfo;
1662:src/Graphics.c ****     Graphics->GPUArray[DevNum].FrameBufferBase = GOPTable->Mode->FrameBufferBase;
1663:src/Graphics.c ****     Graphics->GPUArray[DevNum].FrameBufferSize = GOPTable->Mode->FrameBufferSize;
1664:src/Graphics.c ****     // Can blanketly override Info struct, though (no pointers in it, just raw data)
1665:src/Graphics.c ****     *(Graphics->GPUArray[DevNum].Info) = *(GOPTable->Mode->Info);
1666:src/Graphics.c **** 
1667:src/Graphics.c **** #ifdef GOP_DEBUG_ENABLED
1668:src/Graphics.c ****     Keywait(L"Current mode info assigned.\r\n");
1669:src/Graphics.c **** #endif
1670:src/Graphics.c **** 
1671:src/Graphics.c ****   // End single GPU
1672:src/Graphics.c ****   }
1673:src/Graphics.c **** 
1674:src/Graphics.c ****   // Don't need string names anymore
1675:src/Graphics.c ****   for(UINTN StringNameFree = 0; StringNameFree < NumHandlesInHandleBuffer; StringNameFree++)
1676:src/Graphics.c ****   {
1677:src/Graphics.c ****     GOPStatus = BS->FreePool(NameBuffer[StringNameFree]);
1678:src/Graphics.c ****     if(EFI_ERROR(GOPStatus))
1679:src/Graphics.c ****     {
1680:src/Graphics.c ****       Print(L"NameBuffer[%llu] FreePool error. 0x%llx\r\n", StringNameFree, GOPStatus);
1681:src/Graphics.c ****       return GOPStatus;
1682:src/Graphics.c ****     }
1683:src/Graphics.c ****   }
1684:src/Graphics.c **** 
1685:src/Graphics.c ****   // Don't need NameBuffer anymore
1686:src/Graphics.c ****   GOPStatus = BS->FreePool(NameBuffer);
1687:src/Graphics.c ****   if(EFI_ERROR(GOPStatus))
1688:src/Graphics.c ****   {
1689:src/Graphics.c ****     Print(L"NameBuffer FreePool error. 0x%llx\r\n", GOPStatus);
1690:src/Graphics.c ****     return GOPStatus;
1691:src/Graphics.c ****   }
1692:src/Graphics.c **** 
1693:src/Graphics.c ****   // Don't need GraphicsHandles anymore
1694:src/Graphics.c ****   GOPStatus = BS->FreePool(GraphicsHandles);
1695:src/Graphics.c ****   if(EFI_ERROR(GOPStatus))
1696:src/Graphics.c ****   {
1697:src/Graphics.c ****     Print(L"Error freeing GraphicsHandles pool. 0x%llx\r\n", GOPStatus);
1698:src/Graphics.c ****     return GOPStatus;
1699:src/Graphics.c ****   }
1700:src/Graphics.c **** 
1701:src/Graphics.c **** #ifdef GOP_DEBUG_ENABLED
1702:src/Graphics.c ****     // Data verification
1703:src/Graphics.c ****   for(DevNum = 0; DevNum < Graphics->NumberOfFrameBuffers; DevNum++)
1704:src/Graphics.c ****   {
1705:src/Graphics.c ****     Print(L"\r\nCurrent GOP Mode Info:\r\n");
1706:src/Graphics.c ****     Print(L"Max Mode supported: %u, Current Mode: %u\r\nSize of Mode Info Structure: %llu Bytes\r\n
1707:src/Graphics.c ****     Print(L"FrameBufferBase: 0x%016llx, FrameBufferSize: 0x%llx\r\n", Graphics->GPUArray[DevNum].Fr
1708:src/Graphics.c **** 
1709:src/Graphics.c ****     Print(L"Mode %u of %u (%llu Bytes):\r\n Ver: 0x%x, Res: %ux%u\r\n", Graphics->GPUArray[DevNum].
1710:src/Graphics.c ****     Print(L"PxPerScanLine: %u\r\n", Graphics->GPUArray[DevNum].Info->PixelsPerScanLine);
1711:src/Graphics.c ****     Print(L"PxFormat: 0x%x, PxInfo (R,G,B,Rsvd Masks): 0x%08x, 0x%08x, 0x%08x, 0x%08x\r\n", Graphic
1712:src/Graphics.c ****     Keywait(L"\0");
1713:src/Graphics.c ****   }
1714:src/Graphics.c **** #endif
1715:src/Graphics.c **** 
1716:src/Graphics.c ****   return GOPStatus;
1717:src/Graphics.c **** }
