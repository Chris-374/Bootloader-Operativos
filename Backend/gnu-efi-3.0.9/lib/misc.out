 450:../Backend/gnu-efi-3.0.9/lib/misc.c ****             //
 451:../Backend/gnu-efi-3.0.9/lib/misc.c ****             //
 452:../Backend/gnu-efi-3.0.9/lib/misc.c ****             if (BlkIo->Media->LastBlock < MIN_MBR_DEVICE_SIZE) {
 453:../Backend/gnu-efi-3.0.9/lib/misc.c ****                 //
