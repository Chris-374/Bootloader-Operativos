 776:../Backend/gnu-efi-3.0.9/lib/print.c ****     )
 777:../Backend/gnu-efi-3.0.9/lib/print.c **** // Display string worker for: Print, PrintAt, IPrint, IPrintAt
 778:../Backend/gnu-efi-3.0.9/lib/print.c **** {
 779:../Backend/gnu-efi-3.0.9/lib/print.c ****     PRINT_STATE     ps;
 780:../Backend/gnu-efi-3.0.9/lib/print.c ****     UINTN            back;
 781:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 782:../Backend/gnu-efi-3.0.9/lib/print.c ****     ZeroMem (&ps, sizeof(ps));
 783:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.Context = Out;
 784:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.Output  = (INTN (EFIAPI *)(VOID *, CHAR16 *)) Out->OutputString;
 785:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.SetAttr = (INTN (EFIAPI *)(VOID *, UINTN))  Out->SetAttribute;
 786:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.Attr = Out->Mode->Attribute;
 787:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 788:../Backend/gnu-efi-3.0.9/lib/print.c ****     back = (ps.Attr >> 4) & 0xF;
 789:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.AttrNorm = EFI_TEXT_ATTR(EFI_LIGHTGRAY, back);
 790:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.AttrHighlight = EFI_TEXT_ATTR(EFI_WHITE, back);
 791:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.AttrError = EFI_TEXT_ATTR(EFI_YELLOW, back);
 792:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 793:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (fmt) {
 794:../Backend/gnu-efi-3.0.9/lib/print.c ****         ps.fmt.pw = fmt;
 795:../Backend/gnu-efi-3.0.9/lib/print.c ****     } else {
 796:../Backend/gnu-efi-3.0.9/lib/print.c ****         ps.fmt.Ascii = TRUE;
 797:../Backend/gnu-efi-3.0.9/lib/print.c ****         ps.fmt.pc = fmta;
 798:../Backend/gnu-efi-3.0.9/lib/print.c ****     }
 799:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 800:../Backend/gnu-efi-3.0.9/lib/print.c ****     va_copy(ps.args, args);
 801:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 802:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (Column != (UINTN) -1) {
 803:../Backend/gnu-efi-3.0.9/lib/print.c ****         uefi_call_wrapper(Out->SetCursorPosition, 3, Out, Column, Row);
 804:../Backend/gnu-efi-3.0.9/lib/print.c ****     }
 805:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 806:../Backend/gnu-efi-3.0.9/lib/print.c ****     back = _Print (&ps);
 807:../Backend/gnu-efi-3.0.9/lib/print.c ****     va_end(ps.args);
 808:../Backend/gnu-efi-3.0.9/lib/print.c ****     return back;
 809:../Backend/gnu-efi-3.0.9/lib/print.c **** }
