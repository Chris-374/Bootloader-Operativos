 184:../Backend/gnu-efi-3.0.9/lib/print.c ****     IN INTN         mask,
 185:../Backend/gnu-efi-3.0.9/lib/print.c ****     IN CONST CHAR8  *fmt,
 186:../Backend/gnu-efi-3.0.9/lib/print.c ****     ...
 187:../Backend/gnu-efi-3.0.9/lib/print.c ****     )
 188:../Backend/gnu-efi-3.0.9/lib/print.c **** /*++
 189:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 190:../Backend/gnu-efi-3.0.9/lib/print.c **** Routine Description:
 191:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 192:../Backend/gnu-efi-3.0.9/lib/print.c ****     Prints a formatted unicode string to the default StandardError console
 193:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 194:../Backend/gnu-efi-3.0.9/lib/print.c **** Arguments:
 195:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 196:../Backend/gnu-efi-3.0.9/lib/print.c ****     mask        - Bit mask of debug string.  If a bit is set in the
 197:../Backend/gnu-efi-3.0.9/lib/print.c ****                   mask that is also set in EFIDebug the string is
 198:../Backend/gnu-efi-3.0.9/lib/print.c ****                   printed; otherwise, the string is not printed
 199:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 200:../Backend/gnu-efi-3.0.9/lib/print.c ****     fmt         - Format string
 201:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 202:../Backend/gnu-efi-3.0.9/lib/print.c **** Returns:
 203:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 204:../Backend/gnu-efi-3.0.9/lib/print.c ****     Length of string printed to the StandardError console
 205:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 206:../Backend/gnu-efi-3.0.9/lib/print.c **** --*/
 207:../Backend/gnu-efi-3.0.9/lib/print.c **** {
 208:../Backend/gnu-efi-3.0.9/lib/print.c ****     SIMPLE_TEXT_OUTPUT_INTERFACE    *DbgOut;
 209:../Backend/gnu-efi-3.0.9/lib/print.c ****     PRINT_STATE     ps;
 210:../Backend/gnu-efi-3.0.9/lib/print.c ****     va_list         args;
 211:../Backend/gnu-efi-3.0.9/lib/print.c ****     UINTN           back;
 212:../Backend/gnu-efi-3.0.9/lib/print.c ****     UINTN           attr;
 213:../Backend/gnu-efi-3.0.9/lib/print.c ****     UINTN           SavedAttribute;
 214:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 215:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 216:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (!(EFIDebug & mask)) {
 217:../Backend/gnu-efi-3.0.9/lib/print.c ****         return 0;
 218:../Backend/gnu-efi-3.0.9/lib/print.c ****     }
 219:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 220:../Backend/gnu-efi-3.0.9/lib/print.c ****     va_start (args, fmt);
 221:../Backend/gnu-efi-3.0.9/lib/print.c ****     ZeroMem (&ps, sizeof(ps));
 222:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 223:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.Output = _DbgOut;
 224:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.fmt.Ascii = TRUE;
 225:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.fmt.pc = fmt;
 226:../Backend/gnu-efi-3.0.9/lib/print.c ****     va_copy(ps.args, args);
 227:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.Attr = EFI_TEXT_ATTR(EFI_LIGHTGRAY, EFI_RED);
 228:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 229:../Backend/gnu-efi-3.0.9/lib/print.c ****     DbgOut = LibRuntimeDebugOut;
 230:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 231:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (!DbgOut) {
 232:../Backend/gnu-efi-3.0.9/lib/print.c ****         DbgOut = ST->StdErr;
 233:../Backend/gnu-efi-3.0.9/lib/print.c ****     }
 234:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 235:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (DbgOut) {
 236:../Backend/gnu-efi-3.0.9/lib/print.c ****         ps.Attr = DbgOut->Mode->Attribute;
 237:../Backend/gnu-efi-3.0.9/lib/print.c ****         ps.Context = DbgOut;
 238:../Backend/gnu-efi-3.0.9/lib/print.c ****         ps.SetAttr = (INTN (EFIAPI *)(VOID *, UINTN))  DbgOut->SetAttribute;
 239:../Backend/gnu-efi-3.0.9/lib/print.c ****     }
 240:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 241:../Backend/gnu-efi-3.0.9/lib/print.c ****     SavedAttribute = ps.Attr;
 242:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 243:../Backend/gnu-efi-3.0.9/lib/print.c ****     back = (ps.Attr >> 4) & 0xf;
 244:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.AttrNorm = EFI_TEXT_ATTR(EFI_LIGHTGRAY, back);
 245:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.AttrHighlight = EFI_TEXT_ATTR(EFI_WHITE, back);
 246:../Backend/gnu-efi-3.0.9/lib/print.c ****     ps.AttrError = EFI_TEXT_ATTR(EFI_YELLOW, back);
 247:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 248:../Backend/gnu-efi-3.0.9/lib/print.c ****     attr = ps.AttrNorm;
 249:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 250:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (mask & D_WARN) {
 251:../Backend/gnu-efi-3.0.9/lib/print.c ****         attr = ps.AttrHighlight;
 252:../Backend/gnu-efi-3.0.9/lib/print.c ****     }
 253:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 254:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (mask & D_ERROR) {
 255:../Backend/gnu-efi-3.0.9/lib/print.c ****         attr = ps.AttrError;
 256:../Backend/gnu-efi-3.0.9/lib/print.c ****     }
 257:../Backend/gnu-efi-3.0.9/lib/print.c **** 
 258:../Backend/gnu-efi-3.0.9/lib/print.c ****     if (ps.SetAttr) {
 259:../Backend/gnu-efi-3.0.9/lib/print.c ****         ps.Attr = attr;
 260:../Backend/gnu-efi-3.0.9/lib/print.c ****         uefi_call_wrapper(ps.SetAttr, 2, ps.Context, attr);
