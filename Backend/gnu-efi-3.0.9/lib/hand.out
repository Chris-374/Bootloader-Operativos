 235:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                     switch(SignatureType) {
 236:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                         case SIGNATURE_TYPE_MBR:
 237:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                             if (*((UINT32 *)(Signature)) == *(UINT32 *)(&(HardDrive
 238:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                                 Match = TRUE;
 239:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                             }
 240:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                             break;
 241:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                         case SIGNATURE_TYPE_GUID:
 242:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                             if (CompareGuid((EFI_GUID *)Signature,(EFI_GUID *)(&(Ha
 243:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                                 Match = TRUE;
 244:../Backend/gnu-efi-3.0.9/lib/hand.c ****                                             }
