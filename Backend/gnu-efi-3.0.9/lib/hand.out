 220:../Backend/gnu-efi-3.0.9/lib/hand.c ****             //
 221:../Backend/gnu-efi-3.0.9/lib/hand.c **** 
 222:../Backend/gnu-efi-3.0.9/lib/hand.c ****             for (; ;) {
 223:../Backend/gnu-efi-3.0.9/lib/hand.c **** 
 224:../Backend/gnu-efi-3.0.9/lib/hand.c ****                 if ((DevicePathType(DevPath) == MEDIA_DEVICE_PATH) &&
 225:../Backend/gnu-efi-3.0.9/lib/hand.c ****                     (DevicePathSubType(DevPath) == MEDIA_HARDDRIVE_DP)) {
 226:../Backend/gnu-efi-3.0.9/lib/hand.c **** 
 227:../Backend/gnu-efi-3.0.9/lib/hand.c ****                     HardDriveDevicePath = (HARDDRIVE_DEVICE_PATH *)(DevPath);
 228:../Backend/gnu-efi-3.0.9/lib/hand.c **** 
 229:../Backend/gnu-efi-3.0.9/lib/hand.c ****                     if (PreviousNodeIsHardDriveDevicePath == FALSE) {
