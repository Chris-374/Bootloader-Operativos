  98:../Backend/gnu-efi-3.0.9/lib/crc.c **** /*++
  99:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 100:../Backend/gnu-efi-3.0.9/lib/crc.c **** Routine Description:
 101:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 102:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Updates the CRC32 value in the table header
 103:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 104:../Backend/gnu-efi-3.0.9/lib/crc.c **** Arguments:
 105:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 106:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Hdr     - The table to update
 107:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 108:../Backend/gnu-efi-3.0.9/lib/crc.c **** Returns:
 109:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 110:../Backend/gnu-efi-3.0.9/lib/crc.c ****     None
 111:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 112:../Backend/gnu-efi-3.0.9/lib/crc.c **** --*/
 113:../Backend/gnu-efi-3.0.9/lib/crc.c **** {
 114:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Hdr->CRC32 = 0;
 115:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Hdr->CRC32 = CalculateCrc((UINT8 *)Hdr, Size);
 116:../Backend/gnu-efi-3.0.9/lib/crc.c **** }
 117:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 118:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 119:../Backend/gnu-efi-3.0.9/lib/crc.c **** BOOLEAN
 120:../Backend/gnu-efi-3.0.9/lib/crc.c **** CheckCrc (
 121:../Backend/gnu-efi-3.0.9/lib/crc.c ****     IN UINTN                 MaxSize,
 122:../Backend/gnu-efi-3.0.9/lib/crc.c ****     IN OUT EFI_TABLE_HEADER *Hdr
 123:../Backend/gnu-efi-3.0.9/lib/crc.c ****     )
 124:../Backend/gnu-efi-3.0.9/lib/crc.c **** /*++
 125:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 126:../Backend/gnu-efi-3.0.9/lib/crc.c **** Routine Description:
 127:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 128:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Checks the CRC32 value in the table header
 129:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 130:../Backend/gnu-efi-3.0.9/lib/crc.c **** Arguments:
 131:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 132:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Hdr     - The table to check
 133:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 134:../Backend/gnu-efi-3.0.9/lib/crc.c **** Returns:
 135:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 136:../Backend/gnu-efi-3.0.9/lib/crc.c ****     TRUE if the CRC is OK in the table
 137:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 138:../Backend/gnu-efi-3.0.9/lib/crc.c **** --*/
 139:../Backend/gnu-efi-3.0.9/lib/crc.c **** {
 140:../Backend/gnu-efi-3.0.9/lib/crc.c ****     return CheckCrcAltSize (MaxSize, Hdr->HeaderSize, Hdr);
 141:../Backend/gnu-efi-3.0.9/lib/crc.c **** }
 142:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 143:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 144:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 145:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 146:../Backend/gnu-efi-3.0.9/lib/crc.c **** BOOLEAN
 147:../Backend/gnu-efi-3.0.9/lib/crc.c **** CheckCrcAltSize (
 148:../Backend/gnu-efi-3.0.9/lib/crc.c ****     IN UINTN                 MaxSize,
 149:../Backend/gnu-efi-3.0.9/lib/crc.c ****     IN UINTN                 Size,
 150:../Backend/gnu-efi-3.0.9/lib/crc.c ****     IN OUT EFI_TABLE_HEADER *Hdr
 151:../Backend/gnu-efi-3.0.9/lib/crc.c ****     )
 152:../Backend/gnu-efi-3.0.9/lib/crc.c **** /*++
 153:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 154:../Backend/gnu-efi-3.0.9/lib/crc.c **** Routine Description:
 155:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 156:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Checks the CRC32 value in the table header
 157:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 158:../Backend/gnu-efi-3.0.9/lib/crc.c **** Arguments:
 159:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 160:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Hdr     - The table to check
 161:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 162:../Backend/gnu-efi-3.0.9/lib/crc.c **** Returns:
 163:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 164:../Backend/gnu-efi-3.0.9/lib/crc.c ****     TRUE if the CRC is OK in the table
 165:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 166:../Backend/gnu-efi-3.0.9/lib/crc.c **** --*/
 167:../Backend/gnu-efi-3.0.9/lib/crc.c **** {
 168:../Backend/gnu-efi-3.0.9/lib/crc.c ****     UINT32      Crc;
 169:../Backend/gnu-efi-3.0.9/lib/crc.c ****     UINT32      OrgCrc;
 170:../Backend/gnu-efi-3.0.9/lib/crc.c ****     BOOLEAN     f;
 171:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 172:../Backend/gnu-efi-3.0.9/lib/crc.c ****     if (Size == 0) {
 173:../Backend/gnu-efi-3.0.9/lib/crc.c ****         //
 174:../Backend/gnu-efi-3.0.9/lib/crc.c ****         // If header size is 0 CRC will pass so return FALSE here
 175:../Backend/gnu-efi-3.0.9/lib/crc.c ****         //
 176:../Backend/gnu-efi-3.0.9/lib/crc.c ****         return FALSE;
 177:../Backend/gnu-efi-3.0.9/lib/crc.c ****     }
 178:../Backend/gnu-efi-3.0.9/lib/crc.c ****     if (MaxSize && Size > MaxSize) {
 179:../Backend/gnu-efi-3.0.9/lib/crc.c ****         DEBUG((D_ERROR, "CheckCrc32: Size > MaxSize\n"));
 180:../Backend/gnu-efi-3.0.9/lib/crc.c ****         return FALSE;
 181:../Backend/gnu-efi-3.0.9/lib/crc.c ****     }
 182:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 183:../Backend/gnu-efi-3.0.9/lib/crc.c ****     // clear old crc from header
 184:../Backend/gnu-efi-3.0.9/lib/crc.c ****     OrgCrc = Hdr->CRC32;
 185:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Hdr->CRC32 = 0;
 186:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Crc = CalculateCrc((UINT8 *)Hdr, Size);
 187:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 188:../Backend/gnu-efi-3.0.9/lib/crc.c ****     // set restults
 189:../Backend/gnu-efi-3.0.9/lib/crc.c ****     Hdr->CRC32 = OrgCrc;
 190:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 191:../Backend/gnu-efi-3.0.9/lib/crc.c ****     // return status
 192:../Backend/gnu-efi-3.0.9/lib/crc.c ****     f = OrgCrc == (UINT32) Crc;
 193:../Backend/gnu-efi-3.0.9/lib/crc.c ****     if (!f) {
 194:../Backend/gnu-efi-3.0.9/lib/crc.c ****         DEBUG((D_ERROR, "CheckCrc32: Crc check failed\n"));
 195:../Backend/gnu-efi-3.0.9/lib/crc.c ****     }
 196:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
 197:../Backend/gnu-efi-3.0.9/lib/crc.c ****     return f;
 198:../Backend/gnu-efi-3.0.9/lib/crc.c **** }
 199:../Backend/gnu-efi-3.0.9/lib/crc.c **** 
