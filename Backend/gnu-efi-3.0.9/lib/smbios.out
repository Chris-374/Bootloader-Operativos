  19:../Backend/gnu-efi-3.0.9/lib/smbios.c **** /*
  20:../Backend/gnu-efi-3.0.9/lib/smbios.c ****  * We convert 32 bit values to pointers. In 64 bit mode the compiler will issue a
  21:../Backend/gnu-efi-3.0.9/lib/smbios.c ****  * warning stating that the value is too small for the pointer:
  22:../Backend/gnu-efi-3.0.9/lib/smbios.c ****  * "warning: cast to pointer from integer of different size [-Wint-to-pointer-cast]"
  23:../Backend/gnu-efi-3.0.9/lib/smbios.c ****  * we can safely ignore them here.
  24:../Backend/gnu-efi-3.0.9/lib/smbios.c ****  */
  25:../Backend/gnu-efi-3.0.9/lib/smbios.c **** #ifdef __GNUC__
  26:../Backend/gnu-efi-3.0.9/lib/smbios.c **** #pragma GCC diagnostic ignored "-Wint-to-pointer-cast"
  27:../Backend/gnu-efi-3.0.9/lib/smbios.c **** #endif
