  45:../Backend/gnu-efi-3.0.9/lib/smbios.c **** 
  46:../Backend/gnu-efi-3.0.9/lib/smbios.c ****     Smbios.Hdr = (SMBIOS_HEADER *)SmbiosTable->TableAddress;
  47:../Backend/gnu-efi-3.0.9/lib/smbios.c ****     SmbiosEnd.Raw = (UINT8 *)(SmbiosTable->TableAddress + SmbiosTable->TableLength);
  48:../Backend/gnu-efi-3.0.9/lib/smbios.c ****     for (Index = 0; Index < SmbiosTable->TableLength ; Index++) {
  49:../Backend/gnu-efi-3.0.9/lib/smbios.c ****         if (Smbios.Hdr->Type == 1) {
  50:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             if (Smbios.Hdr->Length < 0x19) {
  51:../Backend/gnu-efi-3.0.9/lib/smbios.c ****                 //
  52:../Backend/gnu-efi-3.0.9/lib/smbios.c ****                 // Older version did not support Guid and Serial number
  53:../Backend/gnu-efi-3.0.9/lib/smbios.c ****                 //
  54:../Backend/gnu-efi-3.0.9/lib/smbios.c ****                 continue;
  55:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             }
  56:../Backend/gnu-efi-3.0.9/lib/smbios.c **** 
  57:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             //
  58:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             // SMBIOS tables are byte packed so we need to do a byte copy to
  59:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             //  prevend alignment faults on IA-64.
  60:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             
  61:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             CopyMem (SystemGuid, &Smbios.Type1->Uuid, sizeof(EFI_GUID));
