  69:../Backend/gnu-efi-3.0.9/lib/smbios.c ****         LibGetSmbiosString (&Smbios, -1);
  70:../Backend/gnu-efi-3.0.9/lib/smbios.c **** 
  71:../Backend/gnu-efi-3.0.9/lib/smbios.c ****         if (Smbios.Raw >= SmbiosEnd.Raw) {
  72:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             //
  73:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             // SMBIOS 2.1 incorrectly stated the length of SmbiosTable as 0x1e. 
  74:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             //  given this we must double check against the lenght of
  75:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             /// the structure. My home PC has this bug.ruthard
  76:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             //
  77:../Backend/gnu-efi-3.0.9/lib/smbios.c ****             return EFI_SUCCESS;
