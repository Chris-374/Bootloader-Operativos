 337:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_DEVICE_PATH *
 338:../Backend/gnu-efi-3.0.9/lib/dpath.c **** UnpackDevicePath (
 339:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *DevPath
 340:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 341:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 342:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH     *Src, *Dest, *NewPath;
 343:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN               Size;
 344:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 345:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 346:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Walk device path and round sizes to valid boundries
 347:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 348:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 349:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Src = DevPath;
 350:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Size = 0;
 351:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     for (; ;) {
 352:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Size += DevicePathNodeLength(Src);
 353:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Size += ALIGN_SIZE(Size);
 354:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 355:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         if (IsDevicePathEnd(Src)) {
 356:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             break;
 357:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         }
 358:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 359:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Src = NextDevicePathNode(Src);
 360:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 361:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 362:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 363:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 364:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Allocate space for the unpacked path
 365:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 366:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 367:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     NewPath = AllocateZeroPool (Size);
 368:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (NewPath) {
 369:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 370:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         ASSERT (((UINTN)NewPath) % MIN_ALIGNMENT_SIZE == 0);
 371:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 372:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 373:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         // Copy each node
 374:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 375:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 376:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Src = DevPath;
 377:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Dest = NewPath;
 378:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         for (; ;) {
 379:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             Size = DevicePathNodeLength(Src);
 380:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             CopyMem (Dest, Src, Size);
 381:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             Size += ALIGN_SIZE(Size);
 382:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             SetDevicePathNodeLength (Dest, Size);
 383:../Backend/gnu-efi-3.0.9/lib/dpath.c **** //            Dest->Type |= EFI_DP_TYPE_UNPACKED; // !!!!!!!!!!!! What?! This completely breaks Dev
 384:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             Dest = (EFI_DEVICE_PATH *) (((UINT8 *) Dest) + Size);
 385:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 386:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             if (IsDevicePathEnd(Src)) {
 387:../Backend/gnu-efi-3.0.9/lib/dpath.c ****                 break;
 388:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             }
 389:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 390:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             Src = NextDevicePathNode(Src);
 391:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         }
 392:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 393:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 394:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return NewPath;
 395:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
