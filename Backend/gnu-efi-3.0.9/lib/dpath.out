 397:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 398:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_DEVICE_PATH*
 399:../Backend/gnu-efi-3.0.9/lib/dpath.c **** AppendDevicePathInstance (
 400:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *Src,
 401:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *Instance
 402:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 403:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 404:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINT8           *Ptr;
 405:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH *DevPath;
 406:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN           SrcSize;
 407:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN           InstanceSize;
 408:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 409:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (Src == NULL) {
 410:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         return DuplicateDevicePath (Instance);
 411:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 412:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     SrcSize = DevicePathSize(Src);
 413:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     InstanceSize = DevicePathSize(Instance);
 414:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Ptr = AllocatePool (SrcSize + InstanceSize);
 415:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     DevPath = (EFI_DEVICE_PATH *)Ptr;
 416:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     ASSERT(DevPath);
 417:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 418:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     CopyMem (Ptr, Src, SrcSize);
 419:../Backend/gnu-efi-3.0.9/lib/dpath.c **** //    FreePool (Src);
 420:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 421:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     while (!IsDevicePathEnd(DevPath)) {
 422:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         DevPath = NextDevicePathNode(DevPath);
 423:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 424:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 425:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Convert the End to an End Instance, since we are
 426:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //  appending another instacne after this one its a good
 427:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //  idea.
 428:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 429:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     DevPath->SubType = END_INSTANCE_DEVICE_PATH_SUBTYPE;
 430:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 431:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     DevPath = NextDevicePathNode(DevPath);
 432:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     CopyMem (DevPath, Instance, InstanceSize);
 433:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return (EFI_DEVICE_PATH *)Ptr;
 434:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
