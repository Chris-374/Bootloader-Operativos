 436:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_STATUS
 437:../Backend/gnu-efi-3.0.9/lib/dpath.c **** LibDevicePathToInterface (
 438:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_GUID             *Protocol,
 439:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH      *FilePath,
 440:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     OUT VOID                **Interface
 441:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 442:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 443:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_STATUS              Status;
 444:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_HANDLE              Device;
 445:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 446:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Status = uefi_call_wrapper(BS->LocateDevicePath, 3, Protocol, &FilePath, &Device);
 447:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 448:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (!EFI_ERROR(Status)) {
 449:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 450:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         // If we didn't get a direct match return not found
 451:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Status = EFI_NOT_FOUND;
 452:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 453:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         if (IsDevicePathEnd(FilePath)) {
 454:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 455:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             //
 456:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             // It was a direct match, lookup the protocol interface
 457:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             //
 458:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 459:../Backend/gnu-efi-3.0.9/lib/dpath.c **** //            Status = uefi_call_wrapper(BS->HandleProtocol, 3, Device, Protocol, Interface); // Le
 460:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             Status = uefi_call_wrapper(BS->OpenProtocol, 6, Device, Protocol, Interface, NULL, NULL
 461:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         }
 462:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 463:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 464:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 465:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // If there was an error, do not return an interface
 466:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 467:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 468:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (EFI_ERROR(Status)) {
 469:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         *Interface = NULL;
 470:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 471:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 472:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return Status;
 473:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
