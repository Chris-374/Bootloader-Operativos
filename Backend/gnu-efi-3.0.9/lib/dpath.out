  49:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_DEVICE_PATH *
  50:../Backend/gnu-efi-3.0.9/lib/dpath.c **** DevicePathInstance (
  51:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN OUT EFI_DEVICE_PATH  **DevicePath,
  52:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     OUT UINTN               *Size
  53:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
  54:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
  55:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH         *Start, *Next, *DevPath;
  56:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN                   Count;
  57:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  58:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     DevPath = *DevicePath;
  59:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Start = DevPath;
  60:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  61:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (!DevPath) {
  62:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         return NULL;
  63:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
  64:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  65:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
  66:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Check for end of device path type
  67:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
  68:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  69:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     for (Count = 0; ; Count++) {
  70:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Next = NextDevicePathNode(DevPath);
  71:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  72:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         if (IsDevicePathEndType(DevPath)) {
  73:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             break;
  74:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         }
  75:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  76:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         if (Count > 01000) {
  77:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             //
  78:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             // BugBug: Debug code to catch bogus device paths
  79:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             //
  80:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             DEBUG((D_ERROR, "DevicePathInstance: DevicePath %x Size %d", *DevicePath, ((UINT8 *) De
  81:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             DumpHex (0, 0, ((UINT8 *) DevPath) - ((UINT8 *) Start), Start);
  82:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             break;
  83:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         }
  84:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  85:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         DevPath = Next;
  86:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
  87:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  88:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     ASSERT (DevicePathSubType(DevPath) == END_ENTIRE_DEVICE_PATH_SUBTYPE ||
  89:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             DevicePathSubType(DevPath) == END_INSTANCE_DEVICE_PATH_SUBTYPE);
  90:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  91:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
  92:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Set next position
  93:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
  94:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  95:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (DevicePathSubType(DevPath) == END_ENTIRE_DEVICE_PATH_SUBTYPE) {
  96:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Next = NULL;
  97:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
  98:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  99:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     *DevicePath = Next;
 100:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 101:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 102:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Return size and start of device path instance
 103:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 104:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 105:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     *Size = ((UINT8 *) DevPath) - ((UINT8 *) Start);
 106:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return Start;
 107:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
 108:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 109:../Backend/gnu-efi-3.0.9/lib/dpath.c **** UINTN
 110:../Backend/gnu-efi-3.0.9/lib/dpath.c **** DevicePathInstanceCount (
 111:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH      *DevicePath
 112:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 113:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 114:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN       Count, Size;
 115:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 116:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Count = 0;
 117:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     while (DevicePathInstance(&DevicePath, &Size)) {
 118:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Count += 1;
 119:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 120:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 121:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return Count;
 122:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
 123:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 124:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 125:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_DEVICE_PATH *
 126:../Backend/gnu-efi-3.0.9/lib/dpath.c **** AppendDevicePath (
 127:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *Src1,
 128:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *Src2
 129:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 130:../Backend/gnu-efi-3.0.9/lib/dpath.c **** // Src1 may have multiple "instances" and each instance is appended
 131:../Backend/gnu-efi-3.0.9/lib/dpath.c **** // Src2 is appended to each instance is Src1.  (E.g., it's possible
 132:../Backend/gnu-efi-3.0.9/lib/dpath.c **** // to append a new instance to the complete device path by passing
 133:../Backend/gnu-efi-3.0.9/lib/dpath.c **** // it in Src2)
 134:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 135:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN               Src1Size, Src1Inst, Src2Size, Size;
 136:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH     *Dst, *Inst;
 137:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINT8               *DstPos;
 138:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 139:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 140:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // If there's only 1 path, just duplicate it
 141:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 142:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 143:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (!Src1) {
 144:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         ASSERT (!IsDevicePathUnpacked (Src2));
 145:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         return DuplicateDevicePath (Src2);
 146:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 147:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 148:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (!Src2) {
 149:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         ASSERT (!IsDevicePathUnpacked (Src1));
 150:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         return DuplicateDevicePath (Src1);
 151:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 152:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 153:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 154:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Verify we're not working with unpacked paths
 155:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 156:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 157:../Backend/gnu-efi-3.0.9/lib/dpath.c **** //    ASSERT (!IsDevicePathUnpacked (Src1));
 158:../Backend/gnu-efi-3.0.9/lib/dpath.c **** //    ASSERT (!IsDevicePathUnpacked (Src2));
 159:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 160:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 161:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Append Src2 to every instance in Src1
 162:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 163:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 164:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Src1Size = DevicePathSize(Src1);
 165:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Src1Inst = DevicePathInstanceCount(Src1);
 166:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Src2Size = DevicePathSize(Src2);
 167:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Size = Src1Size * Src1Inst + Src2Size;
 168:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 169:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Dst = AllocatePool (Size);
 170:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (Dst) {
 171:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         DstPos = (UINT8 *) Dst;
 172:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 173:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 174:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         // Copy all device path instances
 175:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 176:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 177:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         while ((Inst = DevicePathInstance (&Src1, &Size))) {
 178:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 179:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             CopyMem(DstPos, Inst, Size);
 180:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             DstPos += Size;
 181:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 182:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             CopyMem(DstPos, Src2, Src2Size);
 183:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             DstPos += Src2Size;
 184:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 185:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             CopyMem(DstPos, EndInstanceDevicePath, sizeof(EFI_DEVICE_PATH));
 186:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             DstPos += sizeof(EFI_DEVICE_PATH);
 187:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         }
 188:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 189:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         // Change last end marker
 190:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         DstPos -= sizeof(EFI_DEVICE_PATH);
 191:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         CopyMem(DstPos, EndDevicePath, sizeof(EFI_DEVICE_PATH));
 192:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 193:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 194:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return Dst;
 195:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
 196:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 197:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 198:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_DEVICE_PATH *
 199:../Backend/gnu-efi-3.0.9/lib/dpath.c **** AppendDevicePathNode (
 200:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *Src1,
 201:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *Src2
 202:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 203:../Backend/gnu-efi-3.0.9/lib/dpath.c **** // Src1 may have multiple "instances" and each instance is appended
 204:../Backend/gnu-efi-3.0.9/lib/dpath.c **** // Src2 is a signal device path node (without a terminator) that is
 205:../Backend/gnu-efi-3.0.9/lib/dpath.c **** // appended to each instance is Src1.
 206:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 207:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH     *Temp, *Eop;
 208:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN               Length;
 209:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 210:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 211:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Build a Src2 that has a terminator on it
 212:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 213:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 214:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Length = DevicePathNodeLength(Src2);
 215:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Temp = AllocatePool (Length + sizeof(EFI_DEVICE_PATH));
 216:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (!Temp) {
 217:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         return NULL;
 218:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 219:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 220:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     CopyMem (Temp, Src2, Length);
 221:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Eop = NextDevicePathNode(Temp);
 222:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     SetDevicePathEndNode(Eop);
 223:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 224:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 225:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Append device paths
 226:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 227:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 228:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Src1 = AppendDevicePath (Src1, Temp);
 229:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     FreePool (Temp);
 230:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return Src1;
 231:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
 232:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 233:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 234:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_DEVICE_PATH *
 235:../Backend/gnu-efi-3.0.9/lib/dpath.c **** FileDevicePath (
 236:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_HANDLE       Device  OPTIONAL,
 237:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN CHAR16           *FileName
 238:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 239:../Backend/gnu-efi-3.0.9/lib/dpath.c **** /*++
 240:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 241:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     N.B. Results are allocated from pool.  The caller must FreePool
 242:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     the resulting device path structure
 243:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 244:../Backend/gnu-efi-3.0.9/lib/dpath.c **** --*/
 245:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 246:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN                   Size;
 247:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     FILEPATH_DEVICE_PATH    *FilePath;
 248:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH         *Eop, *DevicePath;
 249:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 250:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Size = StrSize(FileName);
 251:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     FilePath = AllocateZeroPool (Size + SIZE_OF_FILEPATH_DEVICE_PATH + sizeof(EFI_DEVICE_PATH));
 252:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     DevicePath = NULL;
 253:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 254:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (FilePath) {
 255:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 256:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 257:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         // Build a file path
 258:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 259:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 260:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         FilePath->Header.Type = MEDIA_DEVICE_PATH;
 261:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         FilePath->Header.SubType = MEDIA_FILEPATH_DP;
 262:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         SetDevicePathNodeLength (&FilePath->Header, Size + SIZE_OF_FILEPATH_DEVICE_PATH);
 263:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         CopyMem (FilePath->PathName, FileName, Size);
 264:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         Eop = NextDevicePathNode(&FilePath->Header);
 265:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         SetDevicePathEndNode(Eop);
 266:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 267:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 268:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         // Append file path to device's device path
 269:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         //
 270:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 271:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         DevicePath = (EFI_DEVICE_PATH *) FilePath;
 272:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         if (Device) {
 273:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             DevicePath = AppendDevicePath (
 274:../Backend/gnu-efi-3.0.9/lib/dpath.c ****                             DevicePathFromHandle(Device),
 275:../Backend/gnu-efi-3.0.9/lib/dpath.c ****                             DevicePath
 276:../Backend/gnu-efi-3.0.9/lib/dpath.c ****                             );
 277:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 278:../Backend/gnu-efi-3.0.9/lib/dpath.c ****             FreePool(FilePath);
 279:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         }
 280:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 281:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 282:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return DevicePath;
 283:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
 284:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 285:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 286:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 287:../Backend/gnu-efi-3.0.9/lib/dpath.c **** UINTN
 288:../Backend/gnu-efi-3.0.9/lib/dpath.c **** DevicePathSize (
 289:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *DevPath
 290:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 291:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 292:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH     *Start;
 293:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 294:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 295:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Search for the end of the device path structure
 296:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 297:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 298:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Start = DevPath;
 299:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     while (!IsDevicePathEnd(DevPath)) {
 300:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         DevPath = NextDevicePathNode(DevPath);
 301:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 302:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 303:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 304:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Compute the size
 305:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 306:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 307:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return ((UINTN) DevPath - (UINTN) Start) + sizeof(EFI_DEVICE_PATH);
 308:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
 309:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 310:../Backend/gnu-efi-3.0.9/lib/dpath.c **** EFI_DEVICE_PATH *
 311:../Backend/gnu-efi-3.0.9/lib/dpath.c **** DuplicateDevicePath (
 312:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     IN EFI_DEVICE_PATH  *DevPath
 313:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     )
 314:../Backend/gnu-efi-3.0.9/lib/dpath.c **** {
 315:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     EFI_DEVICE_PATH     *NewDevPath;
 316:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     UINTN               Size;
 317:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 318:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 319:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 320:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Compute the size
 321:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 322:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 323:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Size = DevicePathSize (DevPath);
 324:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 325:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 326:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     // Make a copy
 327:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     //
 328:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 329:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     NewDevPath = AllocatePool (Size);
 330:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (NewDevPath) {
 331:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         CopyMem (NewDevPath, DevPath, Size);
 332:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
 333:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
 334:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return NewDevPath;
 335:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
