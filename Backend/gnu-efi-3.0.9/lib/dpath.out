  39:../Backend/gnu-efi-3.0.9/lib/dpath.c **** //    Status = uefi_call_wrapper(BS->HandleProtocol, 3, Handle, &DevicePathProtocol, (VOID*)&Device
  40:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     Status = uefi_call_wrapper(BS->OpenProtocol, 6, Handle, &DevicePathProtocol, (VOID*)&DevicePath
  41:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     if (EFI_ERROR(Status)) {
  42:../Backend/gnu-efi-3.0.9/lib/dpath.c ****         DevicePath = NULL;
  43:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     }
  44:../Backend/gnu-efi-3.0.9/lib/dpath.c **** 
  45:../Backend/gnu-efi-3.0.9/lib/dpath.c ****     return DevicePath;
  46:../Backend/gnu-efi-3.0.9/lib/dpath.c **** }
