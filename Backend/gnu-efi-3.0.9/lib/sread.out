  94:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
  95:../Backend/gnu-efi-3.0.9/lib/sread.c ****     // Attempt to access the file via a file system interface
  96:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
  97:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
  98:../Backend/gnu-efi-3.0.9/lib/sread.c ****     FileHandle = NULL;
  99:../Backend/gnu-efi-3.0.9/lib/sread.c ****     Status = uefi_call_wrapper(BS->LocateDevicePath, 3, &FileSystemProtocol, FilePath, DeviceHandle
 100:../Backend/gnu-efi-3.0.9/lib/sread.c ****     if (!EFI_ERROR(Status)) {
 101:../Backend/gnu-efi-3.0.9/lib/sread.c ****         FileHandle = LibOpenRoot (*DeviceHandle);
 102:../Backend/gnu-efi-3.0.9/lib/sread.c ****     }
 103:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 104:../Backend/gnu-efi-3.0.9/lib/sread.c ****     Status = FileHandle ? EFI_SUCCESS : EFI_UNSUPPORTED;
 105:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 106:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 107:../Backend/gnu-efi-3.0.9/lib/sread.c ****     // To access as a filesystem, the filepath should only
 108:../Backend/gnu-efi-3.0.9/lib/sread.c ****     // contain filepath components.  Follow the filepath nodes
 109:../Backend/gnu-efi-3.0.9/lib/sread.c ****     // and find the target file
 110:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 111:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 112:../Backend/gnu-efi-3.0.9/lib/sread.c ****     FilePathNode = (FILEPATH_DEVICE_PATH *) *FilePath;
 113:../Backend/gnu-efi-3.0.9/lib/sread.c ****     while (!IsDevicePathEnd(&FilePathNode->Header)) {
 114:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 115:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 116:../Backend/gnu-efi-3.0.9/lib/sread.c ****         // For filesystem access each node should be a filepath component
 117:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 118:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 119:../Backend/gnu-efi-3.0.9/lib/sread.c ****         if (DevicePathType(&FilePathNode->Header) != MEDIA_DEVICE_PATH ||
 120:../Backend/gnu-efi-3.0.9/lib/sread.c ****             DevicePathSubType(&FilePathNode->Header) != MEDIA_FILEPATH_DP) {
 121:../Backend/gnu-efi-3.0.9/lib/sread.c ****             Status = EFI_UNSUPPORTED;
 122:../Backend/gnu-efi-3.0.9/lib/sread.c ****         }
 123:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 124:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 125:../Backend/gnu-efi-3.0.9/lib/sread.c ****         // If there's been an error, stop
 126:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 127:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 128:../Backend/gnu-efi-3.0.9/lib/sread.c ****         if (EFI_ERROR(Status)) {
 129:../Backend/gnu-efi-3.0.9/lib/sread.c ****             break;
 130:../Backend/gnu-efi-3.0.9/lib/sread.c ****         }
 131:../Backend/gnu-efi-3.0.9/lib/sread.c ****         
 132:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 133:../Backend/gnu-efi-3.0.9/lib/sread.c ****         // Open this file path node
 134:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 135:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 136:../Backend/gnu-efi-3.0.9/lib/sread.c ****         LastHandle = FileHandle;
 137:../Backend/gnu-efi-3.0.9/lib/sread.c ****         FileHandle = NULL;
 138:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 139:../Backend/gnu-efi-3.0.9/lib/sread.c ****         Status = uefi_call_wrapper(
 140:../Backend/gnu-efi-3.0.9/lib/sread.c **** 			LastHandle->Open,
 141:../Backend/gnu-efi-3.0.9/lib/sread.c **** 			5, 
 142:../Backend/gnu-efi-3.0.9/lib/sread.c ****                         LastHandle,
 143:../Backend/gnu-efi-3.0.9/lib/sread.c ****                         &FileHandle,
 144:../Backend/gnu-efi-3.0.9/lib/sread.c ****                         FilePathNode->PathName,
 145:../Backend/gnu-efi-3.0.9/lib/sread.c ****                         EFI_FILE_MODE_READ,
 146:../Backend/gnu-efi-3.0.9/lib/sread.c ****                         0
 147:../Backend/gnu-efi-3.0.9/lib/sread.c ****                         );
 148:../Backend/gnu-efi-3.0.9/lib/sread.c ****         
 149:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 150:../Backend/gnu-efi-3.0.9/lib/sread.c ****         // Close the last node
 151:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 152:../Backend/gnu-efi-3.0.9/lib/sread.c ****         
 153:../Backend/gnu-efi-3.0.9/lib/sread.c ****         uefi_call_wrapper(LastHandle->Close, 1, LastHandle);
 154:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 155:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 156:../Backend/gnu-efi-3.0.9/lib/sread.c ****         // Get the next node
 157:../Backend/gnu-efi-3.0.9/lib/sread.c ****         //
 158:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 159:../Backend/gnu-efi-3.0.9/lib/sread.c ****         FilePathNode = (FILEPATH_DEVICE_PATH *) NextDevicePathNode(&FilePathNode->Header);
 160:../Backend/gnu-efi-3.0.9/lib/sread.c ****     }
 161:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 162:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 163:../Backend/gnu-efi-3.0.9/lib/sread.c ****     // If success, return the FHand
 164:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 165:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 166:../Backend/gnu-efi-3.0.9/lib/sread.c ****     if (!EFI_ERROR(Status)) {
 167:../Backend/gnu-efi-3.0.9/lib/sread.c ****         ASSERT(FileHandle);
 168:../Backend/gnu-efi-3.0.9/lib/sread.c ****         FHand->FileHandle = FileHandle;
 169:../Backend/gnu-efi-3.0.9/lib/sread.c ****         goto Done;
 170:../Backend/gnu-efi-3.0.9/lib/sread.c ****     }
 171:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 172:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 173:../Backend/gnu-efi-3.0.9/lib/sread.c ****     // Cleanup from filesystem access
 174:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 175:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 176:../Backend/gnu-efi-3.0.9/lib/sread.c ****     if (FileHandle) {
 177:../Backend/gnu-efi-3.0.9/lib/sread.c ****         uefi_call_wrapper(FileHandle->Close, 1, FileHandle);
 178:../Backend/gnu-efi-3.0.9/lib/sread.c ****         FileHandle = NULL;
 179:../Backend/gnu-efi-3.0.9/lib/sread.c ****         *FilePath = UserFilePath;
 180:../Backend/gnu-efi-3.0.9/lib/sread.c ****     }
 181:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 182:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 183:../Backend/gnu-efi-3.0.9/lib/sread.c ****     // If the error is something other then unsupported, return it
 184:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
 185:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 186:../Backend/gnu-efi-3.0.9/lib/sread.c ****     if (Status != EFI_UNSUPPORTED) {
 187:../Backend/gnu-efi-3.0.9/lib/sread.c ****         goto Done;
 188:../Backend/gnu-efi-3.0.9/lib/sread.c ****     }
 189:../Backend/gnu-efi-3.0.9/lib/sread.c **** 
 190:../Backend/gnu-efi-3.0.9/lib/sread.c ****     //
